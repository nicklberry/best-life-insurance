---
// TODO:
// If we add thousands of city, ZIP, or neighborhood pages later,
// move location lookup/rendering to a Cloudflare Worker route.
// For now, use Astro getStaticPaths() so pages are built cleanly and deployed through Cloudflare Pages.

import { locations } from '../../../data/locations';
import LocalLandingPage from '../../../components/LocalLandingPage.astro';

export function getStaticPaths() {
  return locations.flatMap((stateLocation) =>
    stateLocation.cities.map((city) => ({
      params: { state: stateLocation.slug, city: city.slug },
      props: {
        stateSlug: stateLocation.slug,
        stateName: stateLocation.name,
        stateAbbreviation: stateLocation.abbreviation,
        isActiveMarket: stateLocation.isActiveMarket,
        cityName: city.name,
        citySlug: city.slug,
        population: city.population,
        localPainPoints: city.localPainPoints ?? [],
      },
    }))
  );
}

interface Props {
  stateSlug: string;
  stateName: string;
  stateAbbreviation: string;
  isActiveMarket: boolean;
  cityName: string;
  citySlug: string;
  population: number;
  localPainPoints: string[];
}

const { stateSlug, stateName, stateAbbreviation, isActiveMarket, cityName, citySlug, population, localPainPoints } = Astro.props;
---

<LocalLandingPage
  stateSlug={stateSlug}
  stateName={stateName}
  stateAbbreviation={stateAbbreviation}
  cityName={cityName}
  citySlug={citySlug}
  population={population}
  isCityPage={true}
  isActiveMarket={isActiveMarket}
  localPainPoints={localPainPoints}
/>
