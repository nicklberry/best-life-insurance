---
import BaseLayout from '../layouts/BaseLayout.astro';
import { LEVEL_CONTENT } from '../lib/surveyScoring';

const levels = (['basic', 'recommended', 'enhanced'] as const).map((key) => ({
  key,
  ...LEVEL_CONTENT[key],
}));
---

<BaseLayout
  title="Family Protection Check | Best Life Insurance Near Me"
  description="Answer a few questions about your household to estimate how much life insurance protection your family may need. Free, no obligation, no pressure."
  keywords="family protection check, how much life insurance do I need, life insurance calculator, family life insurance, protection gap"
>

<div class="fpc-page">

  <!-- ═══ STEP: INTRO ═══ -->
  <div id="fpcIntro" class="fpc-step">
    <section class="fpc-hero">
      <div class="container fpc-hero-inner">
        <p class="eyebrow">Free Family Protection Check</p>
        <h1>Understand how much protection your family may need.</h1>
        <p class="lead">Answer a few questions about your household. We'll help you estimate whether your current coverage may be enough — and what options are available.</p>
        <button id="fpcStartBtn" class="fpc-btn" type="button">Start My Family Protection Check</button>
        <p class="fpc-trust-copy">No pressure. No sales tactics. Educational information to help you make a more informed decision.</p>
      </div>
    </section>
    <div class="fpc-trust-strip">
      <div class="container fpc-trust-row">
        <span>Takes about 2 minutes</span>
        <span>No cost, no obligation</span>
        <span>Educational results</span>
        <span>Coverage varies. We say that a lot.</span>
      </div>
    </div>
  </div>

  <!-- ═══ STEP: CONTACT ═══ -->
  <div id="fpcContact" class="fpc-step" hidden>
    <section class="fpc-section">
      <div class="container fpc-narrow">
        <div class="fpc-step-header">
          <span class="fpc-step-pill">Step 1 of 2 — Contact Information</span>
          <h2>Tell us a bit about yourself.</h2>
          <p class="fpc-step-sub">We'll use this to send your results and connect you with coverage options in your area.</p>
        </div>
        <div class="card fpc-form-card">
          <div class="fpc-honeypot" aria-hidden="true">
            <label for="fpcCompanyWebsite">Company Website</label>
            <input id="fpcCompanyWebsite" name="companyWebsite" type="text" tabindex="-1" autocomplete="off" />
          </div>

          <form id="fpcContactForm" novalidate>
            <div class="fpc-form-grid fpc-two-col">
              <div class="fpc-field">
                <label for="fpcFirstName">First Name</label>
                <input id="fpcFirstName" name="firstName" type="text" autocomplete="given-name" required />
                <p class="fpc-error" data-error="firstName"></p>
              </div>
              <div class="fpc-field">
                <label for="fpcLastName">Last Name</label>
                <input id="fpcLastName" name="lastName" type="text" autocomplete="family-name" required />
                <p class="fpc-error" data-error="lastName"></p>
              </div>
            </div>

            <div class="fpc-form-grid fpc-two-col">
              <div class="fpc-field">
                <label for="fpcEmail">Email</label>
                <input id="fpcEmail" name="email" type="email" autocomplete="email" required />
                <p class="fpc-error" data-error="email"></p>
              </div>
              <div class="fpc-field">
                <label for="fpcPhone">Phone Number</label>
                <input id="fpcPhone" name="phone" type="tel" inputmode="tel" autocomplete="tel" required />
                <p class="fpc-error" data-error="phone"></p>
              </div>
            </div>

            <div class="fpc-field">
              <label for="fpcZip">ZIP Code</label>
              <input id="fpcZip" name="zip" type="text" inputmode="numeric" autocomplete="postal-code" pattern="[0-9]{5}" maxlength="5" required />
              <p class="fpc-error" data-error="zip"></p>
            </div>

            <div class="fpc-consent-card">
              <label class="fpc-consent-label" for="fpcTcpa">
                <input id="fpcTcpa" name="tcpaConsent" type="checkbox" required />
                <span id="fpcConsentText">By checking this box and continuing, you provide your prior express written consent for Best Life Insurance Near Me and participating life insurance providers, licensed insurance agencies, and financial professionals to contact you at the phone number you provided about life insurance and family protection options, including by calls, texts, prerecorded or artificial voice messages, AI-assisted calling, and automated dialing systems. Consent is not a condition of purchase. Message and data rates may apply. You can revoke consent at any time.</span>
              </label>
              <p class="fpc-error" data-error="tcpaConsent"></p>
              <p class="fpc-consent-links">Please review our <a href="/privacy/" target="_blank" rel="noopener">Privacy Policy</a> and <a href="/terms/" target="_blank" rel="noopener">Terms of Use</a>.</p>
            </div>

            <div class="fpc-form-actions">
              <button type="submit" class="fpc-btn">Continue to Check &rarr;</button>
              <button type="button" class="fpc-back-btn" id="fpcContactBack">&larr; Back</button>
            </div>
          </form>
        </div>
      </div>
    </section>
  </div>

  <!-- ═══ STEP: SURVEY ═══ -->
  <div id="fpcSurvey" class="fpc-step" hidden>
    <section class="fpc-section">
      <div class="container fpc-narrow">
        <div class="fpc-step-header">
          <span class="fpc-step-pill">Step 2 of 2 — Family Protection Check</span>
          <h2>Tell us about your household.</h2>
          <p class="fpc-step-sub">These answers help us estimate what level of protection your family may need.</p>
        </div>

        <div class="fpc-progress-wrap">
          <div class="fpc-progress-track" role="progressbar" aria-valuemin="0" aria-valuemax="100" aria-valuenow="0" aria-label="Check progress">
            <div class="fpc-progress-fill" id="fpcProgressFill"></div>
          </div>
          <p class="fpc-progress-label" id="fpcProgressLabel" aria-live="polite">Question 1 of 6</p>
        </div>

        <div class="fpc-questions-wrap">

          <!-- Q1: Age Range -->
          <div class="fpc-question" id="fpcQ1" data-question="ageRange">
            <h3 class="fpc-q-heading">What is your age range?</h3>
            <div class="fpc-options fpc-options-three" data-multiselect="false">
              <button class="fpc-opt" data-value="18-24" type="button">18–24</button>
              <button class="fpc-opt" data-value="25-34" type="button">25–34</button>
              <button class="fpc-opt" data-value="35-44" type="button">35–44</button>
              <button class="fpc-opt" data-value="45-54" type="button">45–54</button>
              <button class="fpc-opt" data-value="55-64" type="button">55–64</button>
              <button class="fpc-opt" data-value="65+" type="button">65 or older</button>
            </div>
          </div>

          <!-- Q2: Marital Status -->
          <div class="fpc-question" id="fpcQ2" data-question="maritalStatus" hidden>
            <h3 class="fpc-q-heading">What is your marital status?</h3>
            <div class="fpc-options fpc-options-two" data-multiselect="false">
              <button class="fpc-opt" data-value="Single" type="button">Single</button>
              <button class="fpc-opt" data-value="Married" type="button">Married</button>
              <button class="fpc-opt" data-value="Divorced" type="button">Divorced</button>
              <button class="fpc-opt" data-value="Widowed" type="button">Widowed</button>
            </div>
          </div>

          <!-- Q3: Number of Children -->
          <div class="fpc-question" id="fpcQ3" data-question="numberOfChildren" hidden>
            <h3 class="fpc-q-heading">How many children do you have?</h3>
            <p class="fpc-q-sub">Include children under 18 or financially dependent on you.</p>
            <div class="fpc-options fpc-options-three" data-multiselect="false">
              <button class="fpc-opt" data-value="0" type="button">None</button>
              <button class="fpc-opt" data-value="1" type="button">1</button>
              <button class="fpc-opt" data-value="2" type="button">2</button>
              <button class="fpc-opt" data-value="3" type="button">3</button>
              <button class="fpc-opt" data-value="4+" type="button">4 or more</button>
            </div>
          </div>

          <!-- Q4: Homeowner -->
          <div class="fpc-question" id="fpcQ4" data-question="homeownerStatus" hidden>
            <h3 class="fpc-q-heading">Do you own your home?</h3>
            <div class="fpc-options fpc-options-two" data-multiselect="false">
              <button class="fpc-opt fpc-opt-lg" data-value="Yes" type="button">Yes</button>
              <button class="fpc-opt fpc-opt-lg" data-value="No" type="button">No</button>
            </div>
          </div>

          <!-- Q5: Annual Income -->
          <div class="fpc-question" id="fpcQ5" data-question="annualIncome" hidden>
            <h3 class="fpc-q-heading">What is your approximate annual household income?</h3>
            <div class="fpc-options" data-multiselect="false">
              <button class="fpc-opt" data-value="Under $30,000" type="button">Under $30,000</button>
              <button class="fpc-opt" data-value="$30,000–$59,999" type="button">$30,000–$59,999</button>
              <button class="fpc-opt" data-value="$60,000–$99,999" type="button">$60,000–$99,999</button>
              <button class="fpc-opt" data-value="$100,000–$149,999" type="button">$100,000–$149,999</button>
              <button class="fpc-opt" data-value="$150,000+" type="button">$150,000 or more</button>
            </div>
          </div>

          <!-- Q6: Existing Coverage -->
          <div class="fpc-question" id="fpcQ6" data-question="existingLifeInsurance" hidden>
            <h3 class="fpc-q-heading">Do you currently have life insurance?</h3>
            <div class="fpc-options fpc-options-three" data-multiselect="false">
              <button class="fpc-opt fpc-opt-lg" data-value="Yes" type="button">Yes</button>
              <button class="fpc-opt fpc-opt-lg" data-value="No" type="button">No</button>
              <button class="fpc-opt fpc-opt-lg" data-value="Not Sure" type="button">Not Sure</button>
            </div>
          </div>

        </div>

        <div class="fpc-survey-nav">
          <button id="fpcSurveyBack" class="fpc-back-btn" type="button" hidden>&larr; Back</button>
          <button id="fpcSurveyNext" class="fpc-btn fpc-btn-sm" type="button" disabled>Continue &rarr;</button>
        </div>
      </div>
    </section>
  </div>

  <!-- ═══ STEP: RESULTS ═══ -->
  <div id="fpcResults" class="fpc-step" hidden>

    <div id="fpcResultsLoading">
      <section class="fpc-section">
        <div class="container fpc-narrow" style="text-align:center">
          <p class="eyebrow">Reviewing your answers</p>
          <p class="lead" style="color:var(--color-gray-700)">Calculating your protection gap score&hellip;</p>
        </div>
      </section>
    </div>

    <div id="fpcResultsContent" hidden>

      <section class="fpc-results-hero">
        <div class="container">
          <p class="eyebrow">Family Protection Check</p>
          <h1>Your Family Protection Check Results</h1>
          <p class="lead" id="fpcResultsSubhead"></p>
        </div>
      </section>

      <!-- Protection Gap Score -->
      <section class="fpc-section" style="background:var(--color-soft-cream)">
        <div class="container fpc-narrow">
          <p class="eyebrow">Protection Gap Score</p>
          <h2>What your answers suggest</h2>
          <div id="fpcScoreCard" class="fpc-score-card" aria-live="polite">
            <!-- Populated by JS -->
          </div>
        </div>
      </section>

      <!-- Recommendation levels -->
      <section class="fpc-section">
        <div class="container">
          <p class="eyebrow">Recommended protection level</p>
          <h2>Basic, Recommended, or Enhanced?</h2>
          <p class="lead fpc-levels-intro">Based on your answers, here is the coverage level that may fit your household. Coverage, availability, and pricing vary by provider, plan, age, and health.</p>
          <div class="fpc-levels-grid">
            {levels.map(({ key, label, tagline, description, features }) => (
              <div class="fpc-level-card" id={`fpcLevel-${key}`}>
                <div class="fpc-badge-wrap">
                  <span class="fpc-rec-badge" id={`fpcBadge-${key}`} hidden>Recommended for Your Household</span>
                </div>
                <p class="fpc-level-label">{label}</p>
                <p class="fpc-level-tagline">{tagline}</p>
                <p class="fpc-level-desc">{description}</p>
                <ul class="fpc-level-features">
                  {features.map((f) => <li>{f}</li>)}
                </ul>
              </div>
            ))}
          </div>
          <p class="fpc-levels-note muted">Coverage details, pricing, and availability vary by provider, plan, age, health, and policy terms. These levels are a starting framework for education, not a guarantee of what any specific policy will include.</p>
        </div>
      </section>

      <!-- Connect Insurance CTA -->
      <section class="fpc-section">
        <div class="container fpc-narrow">
          <div class="fpc-connect-card">
            <div class="fpc-connect-copy">
              <p class="eyebrow fpc-light-eyebrow">Want a more complete picture?</p>
              <h2>Help us understand your current protection.</h2>
              <p>Connecting your insurance information helps us understand what protections your household already has in place and provide more relevant guidance.</p>
            </div>
            <a id="fpcConnectBtn" href="/connect-insurance/" class="fpc-btn fpc-btn-white">Connect My Insurance</a>
          </div>
        </div>
      </section>

      <div class="fpc-disclaimer-wrap">
        <div class="container fpc-narrow">
          <p class="disclosure">Life insurance coverage, pricing, and availability vary by provider, plan, age, health, and policy terms. This check is informational only and does not constitute insurance advice, a quote, or a guarantee of coverage.</p>
        </div>
      </div>

    </div>
  </div>

</div>

</BaseLayout>

<script>
  import { calculateProtectionGapScore, getRecommendationLevel } from '../lib/surveyScoring';
  import { submitLead } from '../lib/leadSubmission';
  import { pushDataLayerEvent } from '../lib/dataLayer';
  import { captureAttribution } from '../lib/attribution';

  let formStartTime = 0;
  let currentQ = 1;
  const TOTAL_Q = 6;
  const contactValues: Record<string, string> = {};
  const surveyAnswers: Record<string, string> = {};

  function showStep(id: string) {
    document.querySelectorAll<HTMLElement>('.fpc-step').forEach((el) => { el.hidden = true; });
    const el = document.getElementById(id);
    if (el) el.hidden = false;
    window.scrollTo({ top: 0, behavior: 'smooth' });
  }

  function getAttribution() {
    const p = new URLSearchParams(window.location.search);
    return {
      website: 'bestlifeinsurancenearme.com' as const,
      pageUrl: window.location.href,
      pagePath: window.location.pathname,
      pageTitle: document.title,
      referrer: document.referrer,
      utmSource: p.get('utm_source') ?? '',
      utmMedium: p.get('utm_medium') ?? '',
      utmCampaign: p.get('utm_campaign') ?? '',
      utmTerm: p.get('utm_term') ?? '',
      utmContent: p.get('utm_content') ?? '',
      userAgent: navigator.userAgent,
    };
  }

  document.getElementById('fpcStartBtn')?.addEventListener('click', () => {
    formStartTime = Date.now();
    const attr = captureAttribution();
    pushDataLayerEvent('family_protection_check_start', {
      lead_type: 'family_protection_check',
      page_path: attr.current_page_path,
      ...attr,
    });
    showStep('fpcContact');
  });

  document.getElementById('fpcContactBack')?.addEventListener('click', () => showStep('fpcIntro'));

  function setError(name: string, msg: string) {
    const errEl = document.querySelector<HTMLElement>(`[data-error="${name}"]`);
    if (errEl) errEl.textContent = msg;
    const inputId = `fpc${name.charAt(0).toUpperCase()}${name.slice(1)}`;
    const input = document.getElementById(inputId);
    if (input) input.setAttribute('aria-invalid', msg ? 'true' : 'false');
  }

  function validateContact(): boolean {
    const form = document.getElementById('fpcContactForm') as HTMLFormElement;
    const fd = new FormData(form);
    const v = Object.fromEntries(fd.entries()) as Record<string, string>;
    let ok = true;

    (['firstName', 'lastName', 'email', 'phone', 'zip'] as const).forEach((f) => {
      if (!(v[f] ?? '').trim()) { setError(f, 'This field is required.'); ok = false; }
      else setError(f, '');
    });

    if (v.email && !/^[^\s@]+@[^\s@]+\.[^\s@]+$/.test(v.email.trim())) {
      setError('email', 'Must be a valid email address.'); ok = false;
    }
    if (v.phone && v.phone.replace(/\D/g, '').length < 10) {
      setError('phone', 'Must contain at least 10 digits.'); ok = false;
    }
    if (v.zip && !/^\d{5}$/.test(v.zip.trim())) {
      setError('zip', 'Must be exactly 5 digits.'); ok = false;
    }
    if (!v.tcpaConsent) {
      setError('tcpaConsent', 'Please check the consent box to continue.'); ok = false;
    } else setError('tcpaConsent', '');

    if (ok) {
      Object.assign(contactValues, {
        firstName: v.firstName.trim(),
        lastName: v.lastName.trim(),
        email: v.email.trim(),
        phone: v.phone.trim(),
        zip: v.zip.trim(),
        companyWebsite: (v.companyWebsite ?? '').trim(),
      });
    }
    return ok;
  }

  document.getElementById('fpcContactForm')?.addEventListener('submit', (e) => {
    e.preventDefault();
    if (validateContact()) {
      const attr = captureAttribution();
      pushDataLayerEvent('family_protection_check_submit', {
        lead_type: 'family_protection_check',
        page_path: attr.current_page_path,
        ...attr,
      });
      showStep('fpcSurvey');
      showQuestion(1);
    }
  });

  const surveyBackBtn = document.getElementById('fpcSurveyBack') as HTMLButtonElement;
  const surveyNextBtn = document.getElementById('fpcSurveyNext') as HTMLButtonElement;
  let advancing = false;

  function hasAnswer(n: number): boolean {
    const key = document.getElementById(`fpcQ${n}`)?.dataset.question ?? '';
    const val = surveyAnswers[key];
    return typeof val === 'string' && val.length > 0;
  }

  function showQuestion(n: number) {
    for (let i = 1; i <= TOTAL_Q; i++) {
      const el = document.getElementById(`fpcQ${i}`);
      if (el) el.hidden = i !== n;
    }
    surveyBackBtn.hidden = n === 1;
    surveyNextBtn.disabled = !hasAnswer(n);
    surveyNextBtn.textContent = n === TOTAL_Q ? 'See My Results →' : 'Continue →';

    const pct = Math.round(((n - 1) / TOTAL_Q) * 100);
    const fill = document.getElementById('fpcProgressFill');
    const track = fill?.parentElement;
    const label = document.getElementById('fpcProgressLabel');
    if (fill) fill.style.width = `${pct}%`;
    if (track) track.setAttribute('aria-valuenow', String(pct));
    if (label) label.textContent = `Question ${n} of ${TOTAL_Q}`;
  }

  function goNext() {
    if (advancing || !hasAnswer(currentQ)) return;
    if (currentQ === TOTAL_Q) { processResults(); return; }
    currentQ++;
    showQuestion(currentQ);
  }

  function goBack() {
    if (currentQ === 1) { showStep('fpcContact'); return; }
    currentQ--;
    showQuestion(currentQ);
  }

  surveyNextBtn.addEventListener('click', goNext);
  surveyBackBtn.addEventListener('click', goBack);

  document.querySelectorAll<HTMLElement>('.fpc-questions-wrap .fpc-options').forEach((grid) => {
    const key = grid.closest<HTMLElement>('.fpc-question')?.dataset.question ?? '';

    grid.querySelectorAll<HTMLElement>('.fpc-opt').forEach((btn) => {
      btn.addEventListener('click', () => {
        grid.querySelectorAll('.fpc-opt').forEach((b) => b.classList.remove('selected'));
        btn.classList.add('selected');
        surveyAnswers[key] = btn.dataset.value ?? '';
        surveyNextBtn.disabled = false;
        advancing = true;
        setTimeout(() => { advancing = false; goNext(); }, 360);
      });
    });
  });

  async function processResults() {
    showStep('fpcResults');

    const score = calculateProtectionGapScore(surveyAnswers as never);
    const level = getRecommendationLevel(score);
    const timeMs = Date.now() - formStartTime;
    const honeypot = contactValues.companyWebsite ?? '';
    const spamStatus: 'pass' | 'suspect' =
      honeypot.length > 0 || timeMs < 3500 ? 'suspect' : 'pass';

    const attr = captureAttribution();
    const eventBase = {
      lead_type: 'family_protection_check',
      protection_gap_score: score,
      recommendation_level: level,
      page_path: attr.current_page_path,
      ...attr,
    };

    pushDataLayerEvent('family_protection_check_complete', eventBase);

    renderResults(score, level);

    const consentText = document.getElementById('fpcConsentText')?.textContent?.trim() ?? '';

    submitLead({
      timestamp: new Date().toISOString(),
      firstName: contactValues.firstName ?? '',
      lastName: contactValues.lastName ?? '',
      email: contactValues.email ?? '',
      phone: contactValues.phone ?? '',
      zip: contactValues.zip ?? '',
      tcpaConsent: true,
      tcpaConsentText: consentText,
      tcpaConsentVersion: '2026-06-01',
      tcpaConsentTimestamp: new Date().toISOString(),
      submission_type: 'life_insurance_lead',
      leadType: 'family_protection_check',
      ageRange: surveyAnswers.ageRange ?? '',
      maritalStatus: surveyAnswers.maritalStatus ?? '',
      numberOfChildren: surveyAnswers.numberOfChildren ?? '',
      homeownerStatus: surveyAnswers.homeownerStatus ?? '',
      annualIncome: surveyAnswers.annualIncome ?? '',
      existingLifeInsurance: surveyAnswers.existingLifeInsurance ?? '',
      protectionGapScore: score,
      recommendationLevel: level,
      companyWebsite: honeypot,
      timeToSubmitMs: timeMs,
      spamCheckStatus: spamStatus,
      ...getAttribution(),
    }).catch(() => { /* non-blocking */ });

    pushDataLayerEvent('life_lead_success', eventBase);
  }

  function renderResults(score: number, level: string) {
    document.getElementById('fpcResultsLoading')?.remove();
    document.getElementById('fpcResultsContent')?.removeAttribute('hidden');

    const subhead = document.getElementById('fpcResultsSubhead');
    if (subhead) subhead.textContent = `Based on your household profile, here is what we found. Protection gap score: ${score} out of 100.`;

    const levelCard = document.getElementById(`fpcLevel-${level}`);
    if (levelCard) levelCard.classList.add('fpc-level-recommended');
    const badge = document.getElementById(`fpcBadge-${level}`);
    if (badge) badge.removeAttribute('hidden');

    const scoreCard = document.getElementById('fpcScoreCard');
    const scoreLabel = level === 'basic' ? 'Lower protection gap detected' : level === 'recommended' ? 'Moderate protection gap detected' : 'Higher protection gap detected';
    const scoreDesc = level === 'basic'
      ? 'Your household profile suggests a relatively lower protection gap. A basic level of coverage may be a reasonable starting point.'
      : level === 'recommended'
      ? 'Your household profile suggests a moderate protection gap. A recommended level of coverage may better align with your family\'s needs.'
      : 'Your household profile suggests a higher protection gap. An enhanced level of coverage may provide more complete protection for your family.';

    if (scoreCard) {
      scoreCard.innerHTML = `
        <div class="fpc-score-inner">
          <div class="fpc-score-num">${score}<span>/100</span></div>
          <div class="fpc-score-text">
            <strong>${scoreLabel}</strong>
            <p>${scoreDesc}</p>
          </div>
        </div>`;
    }

    const connectBtn = document.getElementById('fpcConnectBtn') as HTMLAnchorElement | null;
    if (connectBtn) {
      const p = new URLSearchParams(window.location.search);
      const utmKeys = ['utm_source', 'utm_medium', 'utm_campaign', 'utm_term', 'utm_content'];
      const out = new URLSearchParams();
      utmKeys.forEach((k) => { const v = p.get(k); if (v) out.set(k, v); });
      const qs = out.toString();
      connectBtn.href = `/connect-insurance/${qs ? '?' + qs : ''}`;
    }
  }
</script>

<style>
  .fpc-page { background: var(--color-cream); }
  .fpc-step[hidden] { display: none !important; }

  .fpc-hero {
    padding: 72px 0 40px;
    background: linear-gradient(135deg, #EBF0FA 0%, #FFFFFF 60%);
  }
  .fpc-hero-inner { max-width: 820px; }
  .fpc-hero h1 { font-size: clamp(2.4rem, 7vw, 4.8rem); max-width: 780px; }
  .fpc-trust-copy { margin-top: 18px; font-size: .95rem; color: var(--color-gray-700); max-width: 640px; }

