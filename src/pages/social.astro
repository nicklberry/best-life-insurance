---
import { getCollection } from 'astro:content';
import BaseLayout from '../layouts/BaseLayout.astro';
import { getContentPath } from '../lib/contentPaths';

const allPosts = await getCollection('blog');
const latestPosts = allPosts
  .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf())
  .slice(0, 3);

const secondaryLinks = [
  {
    title: 'Family Protection Check',
    href: '/family-protection-check/?utm_source=social&utm_medium=link_in_bio&utm_campaign=social_page&utm_content=fpc',
  },
  {
    title: 'Compare Life Insurance Options',
    href: '/compare/?utm_source=social&utm_medium=link_in_bio&utm_campaign=social_page&utm_content=compare',
  },
  {
    title: 'Life Insurance Coverage Guides',
    href: '/coverage/?utm_source=social&utm_medium=link_in_bio&utm_campaign=social_page&utm_content=coverage',
  },
];
---

<BaseLayout
  title="Best Life Insurance Near Me Links"
  description="Quick links for Best Life Insurance Near Me, including the Family Protection Check, latest articles, and coverage guides."
  canonical="https://bestlifeinsurancenearme.com/social/"
>
  <div class="social-page">
    <header class="brand-header">
      <div class="brand-icon" aria-hidden="true">
        <svg width="32" height="32" viewBox="0 0 24 24" fill="none"><path d="M12 1L3 5v6c0 5.55 3.84 10.74 9 12 5.16-1.26 9-6.45 9-12V5l-9-4z" fill="#2D5B9F"/></svg>
      </div>
      <h1 class="brand-name">Best Life Insurance Near Me</h1>
      <p class="tagline">Protect the people who depend on you.</p>
      <span class="badge">Educational content only. Coverage varies.</span>
    </header>

    <a href="/family-protection-check/?utm_source=social&utm_medium=link_in_bio&utm_campaign=social_page&utm_content=fpc_primary" class="card card--primary">
      <div class="card__inner">
        <span class="card__arrow" aria-hidden="true">→</span>
        <div>
          <div class="card__title">Start My Family Protection Check</div>
          <div class="card__desc">Understand how much life insurance protection your family may need. Takes about 2 minutes.</div>
        </div>
      </div>
    </a>

    {latestPosts.length > 0 && (
      <section class="section">
        <h2 class="section-label">Latest Articles</h2>
        <div class="card-list">
          {latestPosts.map((post) => (
            <a href={getContentPath('blog', post)} class="card card--post">
              <div class="card__inner">
                <span class="card__arrow" aria-hidden="true">→</span>
                <div>
                  <div class="card__title">{post.data.title}</div>
                  {post.data.description && (
                    <div class="card__desc">{post.data.description}</div>
                  )}
                </div>
              </div>
            </a>
          ))}
        </div>
      </section>
    )}

    <div class="card-list">
      {secondaryLinks.map((link) => (
        <a href={link.href} class="card card--secondary">
          <div class="card__inner">
            <span class="card__arrow" aria-hidden="true">→</span>
            <div class="card__title">{link.title}</div>
          </div>
        </a>
      ))}
    </div>

    <a href="/" class="card card--website">
      <div class="card__inner">
        <span class="card__arrow" aria-hidden="true">🛡</span>
        <div>
          <div class="card__title">Visit the Website</div>
          <div class="card__desc">bestlifeinsurancenearme.com</div>
        </div>
      </div>
    </a>
  </div>
</BaseLayout>

<style>
  .social-page { min-height: 100vh; background: var(--color-cream); display: flex; flex-direction: column; align-items: center; padding: 2.5rem 1rem 4rem; gap: 0.75rem; }
  .brand-header { display: flex; flex-direction: column; align-items: center; text-align: center; gap: 0.5rem; margin-bottom: 0.75rem; width: 100%; max-width: 560px; }
  .brand-icon { margin-bottom: 0.25rem; }
  .brand-name { font-size: clamp(1.25rem, 4vw, 1.6rem); font-weight: 800; color: var(--color-navy); margin: 0; line-height: 1.2; }
  .tagline { font-size: clamp(0.9rem, 2.5vw, 1.05rem); color: var(--color-charcoal); margin: 0; line-height: 1.4; }
  .badge { display: inline-block; background: var(--color-light-blue); border: 1px solid rgba(45,91,159,.25); color: var(--color-blue); font-size: 0.75rem; font-weight: 600; padding: 0.25rem 0.75rem; border-radius: 999px; margin-top: 0.25rem; }
  .card { display: block; width: 100%; max-width: 560px; background: #fff; border-radius: var(--radius-lg, 24px); box-shadow: var(--shadow-card, 0 4px 24px rgba(16,32,51,0.08)); text-decoration: none; color: inherit; transition: transform 0.15s ease, box-shadow 0.15s ease; }
  .card:hover, .card:focus-visible { transform: translateY(-2px); box-shadow: 0 8px 36px rgba(16,32,51,0.14); outline: none; }
  .card:focus-visible { outline: 3px solid var(--color-blue); outline-offset: 2px; }
  .card__inner { display: flex; align-items: center; gap: 1rem; padding: 1.1rem 1.25rem; }
  .card__arrow { font-size: 1.1rem; color: var(--color-blue); flex-shrink: 0; font-style: normal; }
  .card__title { font-weight: 700; font-size: clamp(0.95rem, 2.5vw, 1.05rem); color: var(--color-navy); line-height: 1.3; }
  .card__desc { font-size: 0.875rem; color: var(--color-gray-600); margin-top: 0.2rem; line-height: 1.4; }
  .card--primary { background: var(--color-navy); border-radius: var(--radius-lg, 24px); }
  .card--primary .card__title { color: #fff; font-size: clamp(1.05rem, 3vw, 1.2rem); }
  .card--primary .card__desc { color: rgba(255,255,255,0.88); }
  .card--primary .card__arrow { color: rgba(255,255,255,0.9); font-size: 1.25rem; }
  .card--primary:hover, .card--primary:focus-visible { background: #0d1a29; }
  .card--post .card__title { font-size: clamp(0.9rem, 2.5vw, 1rem); }
  .card--website .card__desc { color: var(--color-blue); font-weight: 500; }
  .section { width: 100%; max-width: 560px; display: flex; flex-direction: column; gap: 0.6rem; }
  .section-label { font-size: 0.75rem; font-weight: 700; letter-spacing: 0.08em; text-transform: uppercase; color: var(--color-gray-600); margin: 0; padding: 0.5rem 0 0.1rem; }
  .card-list { width: 100%; max-width: 560px; display: flex; flex-direction: column; gap: 0.6rem; }
</style>
