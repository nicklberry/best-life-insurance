---
import { getCollection } from 'astro:content';
import BaseLayout from '../layouts/BaseLayout.astro';
import { getContentPath } from '../lib/contentPaths';

const allPosts = await getCollection('blog');
const latestPosts = allPosts
  .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf())
  .slice(0, 3);

const secondaryLinks = [
  {
    title: 'Compare Home Warranty Options',
    href: '/compare/?utm_source=social&utm_medium=link_in_bio&utm_campaign=social_page&utm_content=compare',
  },
  {
    title: 'Home Protection Gap Check',
    href: '/home-protection-gap-check/?utm_source=social&utm_medium=link_in_bio&utm_campaign=social_page&utm_content=gap_check',
  },
  {
    title: 'Learn What Home Warranties Cover',
    href: '/home-warranty/?utm_source=social&utm_medium=link_in_bio&utm_campaign=social_page&utm_content=home_warranty',
  },
];

const socialLinks = [
  {
    label: 'Facebook',
    href: 'https://www.facebook.com/besthomewarrantynearme/',
    icon: `<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor" width="22" height="22" aria-hidden="true"><path d="M24 12.073C24 5.405 18.627 0 12 0S0 5.405 0 12.073C0 18.1 4.388 23.094 10.125 24v-8.437H7.078v-3.49h3.047v-2.66c0-3.025 1.792-4.697 4.533-4.697 1.312 0 2.686.235 2.686.235v2.97h-1.513c-1.491 0-1.956.93-1.956 1.874v2.278h3.328l-.532 3.49h-2.796V24C19.612 23.094 24 18.1 24 12.073z"/></svg>`,
  },
  {
    label: 'Instagram',
    href: 'https://www.instagram.com/besthomewarrantynearme/',
    icon: `<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor" width="22" height="22" aria-hidden="true"><path d="M12 2.163c3.204 0 3.584.012 4.85.07 3.252.148 4.771 1.691 4.919 4.919.058 1.265.069 1.645.069 4.849 0 3.205-.012 3.584-.069 4.849-.149 3.225-1.664 4.771-4.919 4.919-1.266.058-1.644.07-4.85.07-3.204 0-3.584-.012-4.849-.07-3.26-.149-4.771-1.699-4.919-4.92-.058-1.265-.07-1.644-.07-4.849 0-3.204.013-3.583.07-4.849.149-3.227 1.664-4.771 4.919-4.919 1.266-.057 1.645-.069 4.849-.069zM12 0C8.741 0 8.333.014 7.053.072 2.695.272.273 2.69.073 7.052.014 8.333 0 8.741 0 12c0 3.259.014 3.668.072 4.948.2 4.358 2.618 6.78 6.98 6.98C8.333 23.986 8.741 24 12 24c3.259 0 3.668-.014 4.948-.072 4.354-.2 6.782-2.618 6.979-6.98.059-1.28.073-1.689.073-4.948 0-3.259-.014-3.667-.072-4.947-.196-4.354-2.617-6.78-6.979-6.98C15.668.014 15.259 0 12 0zm0 5.838a6.162 6.162 0 100 12.324 6.162 6.162 0 000-12.324zM12 16a4 4 0 110-8 4 4 0 010 8zm6.406-11.845a1.44 1.44 0 100 2.881 1.44 1.44 0 000-2.881z"/></svg>`,
  },
  {
    label: 'YouTube',
    href: 'https://www.youtube.com/@besthomewarrantynearme',
    icon: `<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor" width="22" height="22" aria-hidden="true"><path d="M23.498 6.186a3.016 3.016 0 00-2.122-2.136C19.505 3.545 12 3.545 12 3.545s-7.505 0-9.377.505A3.017 3.017 0 00.502 6.186C0 8.07 0 12 0 12s0 3.93.502 5.814a3.016 3.016 0 002.122 2.136c1.871.505 9.376.505 9.376.505s7.505 0 9.377-.505a3.015 3.015 0 002.122-2.136C24 15.93 24 12 24 12s0-3.93-.502-5.814zM9.545 15.568V8.432L15.818 12l-6.273 3.568z"/></svg>`,
  },
  {
    label: 'TikTok',
    href: 'https://www.tiktok.com/@besthomewarrantynearme',
    icon: `<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor" width="22" height="22" aria-hidden="true"><path d="M12.525.02c1.31-.02 2.61-.01 3.91-.02.08 1.53.63 3.09 1.75 4.17 1.12 1.11 2.7 1.62 4.24 1.79v4.03c-1.44-.05-2.89-.35-4.2-.97-.57-.26-1.1-.59-1.62-.93-.01 2.92.01 5.84-.02 8.75-.08 1.4-.54 2.79-1.35 3.94-1.31 1.92-3.58 3.17-5.91 3.21-1.43.08-2.86-.31-4.08-1.03-2.02-1.19-3.44-3.37-3.65-5.71-.02-.5-.03-1-.01-1.49.18-1.9 1.12-3.72 2.58-4.96 1.66-1.44 3.98-2.13 6.15-1.72.02 1.48-.04 2.96-.04 4.44-.99-.32-2.15-.23-3.02.37-.63.41-1.11 1.04-1.36 1.75-.21.51-.15 1.07-.14 1.61.24 1.64 1.82 3.02 3.5 2.87 1.12-.01 2.19-.66 2.77-1.61.19-.33.4-.67.41-1.06.1-1.79.06-3.57.07-5.36.01-4.03-.01-8.05.02-12.07z"/></svg>`,
  },
];
---

<BaseLayout
  title="Best Home Warranty Near Me Links"
  description="Quick links for Best Home Warranty Near Me, including coverage checks, latest articles, and social channels."
  canonical="https://besthomewarrantynearme.com/social/"
>
  <div class="social-page">
    <!-- Header -->
    <header class="brand-header">
      <div class="brand-icon">🏠</div>
      <h1 class="brand-name">Best Home Warranty Near Me</h1>
      <p class="tagline">Home warranty help without the corporate snoozefest.</p>
      <span class="badge">Coverage varies. We say that a lot.</span>
    </header>

    <!-- Primary CTA -->
    <a
      href="/home-protection-gap-check/?utm_source=social&utm_medium=link_in_bio&utm_campaign=social_page&utm_content=coverage_check"
      class="card card--primary"
    >
      <div class="card__inner">
        <span class="card__arrow" aria-hidden="true">→</span>
        <div>
          <div class="card__title">Check Coverage Options</div>
          <div class="card__desc">See home warranty options near you before your house picks a fight with your wallet.</div>
        </div>
      </div>
    </a>

    <!-- Latest Blog Posts -->
    {latestPosts.length > 0 && (
      <section class="section">
        <h2 class="section-label">Latest Articles</h2>
        <div class="card-list">
          {latestPosts.map((post) => (
            <a href={getContentPath('blog', post)} class="card card--post">
              <div class="card__inner">
                <span class="card__arrow" aria-hidden="true">→</span>
                <div>
                  <div class="card__title">{post.data.title}</div>
                  {post.data.description && (
                    <div class="card__desc">{post.data.description}</div>
                  )}
                </div>
              </div>
            </a>
          ))}
        </div>
      </section>
    )}

    <!-- Secondary Links -->
    <div class="card-list">
      {secondaryLinks.map((link) => (
        <a href={link.href} class="card card--secondary">
          <div class="card__inner">
            <span class="card__arrow" aria-hidden="true">→</span>
            <div class="card__title">{link.title}</div>
          </div>
        </a>
      ))}
    </div>

    <!-- Social Footer -->
    <section class="social-section">
      <h2 class="section-label">Follow Along</h2>
      <p class="social-copy">
        Home warranty tips, homeowner education, coverage explanations, and occasional reminders that your water heater is plotting against you.
      </p>
      <div class="social-links">
        {socialLinks.map((s) => (
          <a
            href={s.href}
            target="_blank"
            rel="noopener noreferrer"
            class="social-link"
            aria-label={`${s.label} — Best Home Warranty Near Me`}
          >
            <Fragment set:html={s.icon} />
            <span>{s.label}</span>
          </a>
        ))}
      </div>
    </section>

    <!-- Website Link -->
    <a href="/" class="card card--website">
      <div class="card__inner">
        <span class="card__arrow" aria-hidden="true">🏠</span>
        <div>
          <div class="card__title">Visit the Website</div>
          <div class="card__desc">besthomewarrantynearme.com</div>
        </div>
      </div>
    </a>
  </div>
</BaseLayout>

<style>
  .social-page {
    min-height: 100vh;
    background: var(--color-cream);
    display: flex;
    flex-direction: column;
    align-items: center;
    padding: 2.5rem 1rem 4rem;
    gap: 0.75rem;
  }

  /* Brand header */
  .brand-header {
    display: flex;
    flex-direction: column;
    align-items: center;
    text-align: center;
    gap: 0.5rem;
    margin-bottom: 0.75rem;
    width: 100%;
    max-width: 560px;
  }

  .brand-icon {
    font-size: 2.5rem;
    line-height: 1;
    margin-bottom: 0.25rem;
  }

  .brand-name {
    font-size: clamp(1.25rem, 4vw, 1.6rem);
    font-weight: 800;
    color: var(--color-navy);
    margin: 0;
    line-height: 1.2;
  }

  .tagline {
    font-size: clamp(0.9rem, 2.5vw, 1.05rem);
    color: var(--color-charcoal);
    margin: 0;
    line-height: 1.4;
  }

  .badge {
    display: inline-block;
    background: var(--color-soft-cream);
    border: 1px solid rgba(249, 115, 22, 0.25);
    color: var(--color-orange);
    font-size: 0.75rem;
    font-weight: 600;
    padding: 0.25rem 0.75rem;
    border-radius: 999px;
    margin-top: 0.25rem;
  }

  /* Cards */
  .card {
    display: block;
    width: 100%;
    max-width: 560px;
    background: #fff;
    border-radius: var(--radius-lg, 24px);
    box-shadow: var(--shadow-card, 0 4px 24px rgba(16,32,51,0.08));
    text-decoration: none;
    color: inherit;
    transition: transform 0.15s ease, box-shadow 0.15s ease;
  }

  .card:hover,
  .card:focus-visible {
    transform: translateY(-2px);
    box-shadow: 0 8px 36px rgba(16, 32, 51, 0.14);
    outline: none;
  }

  .card:focus-visible {
    outline: 3px solid var(--color-orange);
    outline-offset: 2px;
  }

  .card__inner {
    display: flex;
    align-items: center;
    gap: 1rem;
    padding: 1.1rem 1.25rem;
  }

  .card__arrow {
    font-size: 1.1rem;
    color: var(--color-orange);
    flex-shrink: 0;
    font-style: normal;
  }

  .card__title {
    font-weight: 700;
    font-size: clamp(0.95rem, 2.5vw, 1.05rem);
    color: var(--color-navy);
    line-height: 1.3;
  }

  .card__desc {
    font-size: 0.875rem;
    color: var(--color-gray-600);
    margin-top: 0.2rem;
    line-height: 1.4;
  }

  /* Primary CTA card */
  .card--primary {
    background: var(--color-orange);
    border-radius: var(--radius-lg, 24px);
  }

  .card--primary .card__title {
    color: #fff;
    font-size: clamp(1.05rem, 3vw, 1.2rem);
  }

  .card--primary .card__desc {
    color: rgba(255, 255, 255, 0.88);
  }

  .card--primary .card__arrow {
    color: rgba(255, 255, 255, 0.9);
    font-size: 1.25rem;
  }

  .card--primary:hover,
  .card--primary:focus-visible {
    background: #ea6c10;
  }

  /* Blog post cards */
  .card--post .card__title {
    font-size: clamp(0.9rem, 2.5vw, 1rem);
  }

  /* Website card */
  .card--website .card__desc {
    color: var(--color-orange);
    font-weight: 500;
  }

  /* Section label */
  .section {
    width: 100%;
    max-width: 560px;
    display: flex;
    flex-direction: column;
    gap: 0.6rem;
  }

  .section-label {
    font-size: 0.75rem;
    font-weight: 700;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--color-gray-600);
    margin: 0;
    padding: 0.5rem 0 0.1rem;
  }

  .card-list {
    width: 100%;
    max-width: 560px;
    display: flex;
    flex-direction: column;
    gap: 0.6rem;
  }

  /* Social section */
  .social-section {
    width: 100%;
    max-width: 560px;
    background: #fff;
    border-radius: var(--radius-lg, 24px);
    box-shadow: var(--shadow-card, 0 4px 24px rgba(16,32,51,0.08));
    padding: 1.5rem 1.25rem;
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
    margin-top: 0.25rem;
  }

  .social-section .section-label {
    padding: 0;
  }

  .social-copy {
    font-size: 0.875rem;
    color: var(--color-gray-600);
    line-height: 1.5;
    margin: 0;
  }

  .social-links {
    display: flex;
    gap: 0.6rem;
    flex-wrap: wrap;
  }

  .social-link {
    display: inline-flex;
    align-items: center;
    gap: 0.4rem;
    background: var(--color-soft-cream, #FFF7EC);
    color: var(--color-navy);
    text-decoration: none;
    font-size: 0.875rem;
    font-weight: 600;
    padding: 0.5rem 0.9rem 0.5rem 0.7rem;
    border-radius: 999px;
    border: 1px solid rgba(16, 32, 51, 0.08);
    transition: background 0.15s ease, color 0.15s ease, transform 0.15s ease;
  }

  .social-link:hover,
  .social-link:focus-visible {
    background: var(--color-orange);
    color: #fff;
    transform: translateY(-1px);
    outline: none;
  }

  .social-link:focus-visible {
    outline: 3px solid var(--color-orange);
    outline-offset: 2px;
  }

  /* Spacing between sections */
  .section,
  .card-list,
  .social-section,
  .card {
    margin-top: 0;
  }

  .social-page > * + * {
    margin-top: 0;
  }
</style>
