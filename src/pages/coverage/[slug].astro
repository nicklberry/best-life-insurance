---
import { getCollection, render } from 'astro:content';
import ContentLayout from '../../layouts/ContentLayout.astro';
import { findEntryBySlug } from '../../lib/contentPaths';

export async function getStaticPaths() {
  const entries = await getCollection('coverage');

  return entries.map((entry) => ({
    params: { slug: entry.id }
  }));
}
const entries = await getCollection('coverage');
const entry = findEntryBySlug(entries, Astro.params.slug);
const { Content } = await render(entry);
---
<ContentLayout title={entry.data.title} description={entry.data.description} seoTitle={entry.data.seoTitle} seoDescription={entry.data.seoDescription} eyebrow="Coverage guide">
  <div class="grid grid-2"><div class="card"><h2>May be covered</h2><ul class="list-check">{entry.data.coveredItems.map((item) => <li>{item}</li>)}</ul></div><div class="card"><h2>Common exclusions</h2><ul class="list-x">{entry.data.commonExclusions.map((item) => <li>{item}</li>)}</ul></div></div>
  <Content />
</ContentLayout>
