---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout
  title="Home Protection Profile | Best Home Warranty Near Me"
  description="Answer a few quick questions about your home so we can recommend the right level of home warranty protection for your systems, appliances, and repair concerns."
>

  <section class="survey-hero">
    <div class="container survey-hero-inner">
      <p class="eyebrow">Home Protection Checkup</p>
      <h1>Let&rsquo;s find the right level of protection for your home.</h1>
      <p class="lead">Answer a few quick questions so we can recommend options that fit your home, systems, appliances, and repair concerns.</p>
    </div>
  </section>

  <section class="survey-body">
    <div class="container survey-container">

      <div
        class="progress-track"
        role="progressbar"
        aria-valuemin="0"
        aria-valuemax="100"
        aria-valuenow="0"
        aria-label="Survey progress"
      >
        <div class="progress-fill" id="progressFill"></div>
      </div>
      <p class="progress-label" id="progressLabel" aria-live="polite">Question 1 of 7</p>

      <div class="steps-container">

        <!-- Step 1: Home age -->
        <div class="step" data-step="1">
          <h2 class="q-heading">How old is your home?</h2>
          <div class="option-grid" data-question="homeAge" data-multiselect="false">
            <button class="option-btn" data-value="under5" type="button">Less than 5 years</button>
            <button class="option-btn" data-value="5to10" type="button">5&ndash;10 years</button>
            <button class="option-btn" data-value="11to20" type="button">11&ndash;20 years</button>
            <button class="option-btn" data-value="21to40" type="button">21&ndash;40 years</button>
            <button class="option-btn" data-value="over40" type="button">More than 40 years</button>
            <button class="option-btn" data-value="notSure" type="button">Not sure</button>
          </div>
        </div>

        <!-- Step 2: HVAC age -->
        <div class="step" data-step="2" hidden>
          <h2 class="q-heading">How old is your HVAC system?</h2>
          <p class="q-sub">This includes your furnace, air conditioner, or heat pump.</p>
          <div class="option-grid" data-question="hvacAge" data-multiselect="false">
            <button class="option-btn" data-value="under5" type="button">Less than 5 years</button>
            <button class="option-btn" data-value="5to10" type="button">5&ndash;10 years</button>
            <button class="option-btn" data-value="11to15" type="button">11&ndash;15 years</button>
            <button class="option-btn" data-value="over15" type="button">15+ years</button>
            <button class="option-btn" data-value="notSure" type="button">Not sure</button>
          </div>
        </div>

        <!-- Step 3: Water heater age -->
        <div class="step" data-step="3" hidden>
          <h2 class="q-heading">How old is your water heater?</h2>
          <div class="option-grid" data-question="waterHeaterAge" data-multiselect="false">
            <button class="option-btn" data-value="under5" type="button">Less than 5 years</button>
            <button class="option-btn" data-value="5to10" type="button">5&ndash;10 years</button>
            <button class="option-btn" data-value="11to15" type="button">11&ndash;15 years</button>
            <button class="option-btn" data-value="over15" type="button">15+ years</button>
            <button class="option-btn" data-value="notSure" type="button">Not sure</button>
          </div>
        </div>

        <!-- Step 4: Top concerns (multi-select) -->
        <div class="step" data-step="4" hidden>
          <h2 class="q-heading">What worries you most?</h2>
          <p class="q-sub">Select all that apply, then tap Continue.</p>
          <div class="option-grid option-grid-wrap" data-question="topConcerns" data-multiselect="true">
            <button class="option-btn" data-value="hvac" type="button">HVAC breakdown</button>
            <button class="option-btn" data-value="plumbing" type="button">Plumbing repairs</button>
            <button class="option-btn" data-value="electrical" type="button">Electrical issues</button>
            <button class="option-btn" data-value="waterHeater" type="button">Water heater failure</button>
            <button class="option-btn" data-value="kitchen" type="button">Kitchen appliances</button>
            <button class="option-btn" data-value="laundry" type="button">Laundry appliances</button>
            <button class="option-btn" data-value="unexpected" type="button">Unexpected repair bills</button>
            <button class="option-btn" data-value="notSure" type="button">Not sure</button>
          </div>
        </div>

        <!-- Step 5: Older appliances -->
        <div class="step" data-step="5" hidden>
          <h2 class="q-heading">How many major appliances are over 8 years old?</h2>
          <p class="q-sub">Think refrigerator, dishwasher, washer, dryer, range, oven.</p>
          <div class="option-grid" data-question="olderApplianceCount" data-multiselect="false">
            <button class="option-btn" data-value="none" type="button">None</button>
            <button class="option-btn" data-value="1to2" type="button">1&ndash;2</button>
            <button class="option-btn" data-value="3to4" type="button">3&ndash;4</button>
            <button class="option-btn" data-value="over5" type="button">5 or more</button>
            <button class="option-btn" data-value="notSure" type="button">Not sure</button>
          </div>
        </div>

        <!-- Step 6: Recent major repair -->
        <div class="step" data-step="6" hidden>
          <h2 class="q-heading">Have you had a major home repair in the last 3 years?</h2>
          <p class="q-sub">HVAC replacement, major plumbing work, roof repair, electrical panel upgrade, and similar.</p>
          <div class="option-grid option-grid-two" data-question="recentMajorRepair" data-multiselect="false">
            <button class="option-btn option-btn-lg" data-value="yes" type="button">Yes</button>
            <button class="option-btn option-btn-lg" data-value="no" type="button">No</button>
          </div>
        </div>

        <!-- Step 7: Protection preference -->
        <div class="step" data-step="7" hidden>
          <h2 class="q-heading">What is most important to you?</h2>
          <div class="option-grid option-grid-three" data-question="protectionPreference" data-multiselect="false">
            <button class="option-btn option-btn-rich" data-value="lowest" type="button">
              <strong>Lowest monthly cost</strong>
              <span>Keep monthly spending down, cover the basics</span>
            </button>
            <button class="option-btn option-btn-rich" data-value="balanced" type="button">
              <strong>Balanced protection and price</strong>
              <span>Solid coverage at a reasonable cost</span>
            </button>
            <button class="option-btn option-btn-rich" data-value="maximum" type="button">
              <strong>Maximum protection</strong>
              <span>Broadest coverage, fewest surprises</span>
            </button>
          </div>
        </div>

      </div><!-- /steps-container -->

      <div class="survey-nav">
        <button class="nav-back" id="backBtn" type="button" hidden>&#8592; Back</button>
        <button class="nav-continue" id="nextBtn" type="button" disabled>Continue &#8594;</button>
      </div>

    </div>
  </section>

</BaseLayout>

<script>
  import { calculateRiskScore, getRecommendedTier } from '../lib/surveyScoring';

  const TOTAL_STEPS = 7;
  let currentStep = 1;
  let advancing = false;
  const answers: Record<string, string | string[]> = {};

  const progressFill = document.getElementById('progressFill') as HTMLElement;
  const progressLabel = document.getElementById('progressLabel') as HTMLElement;
  const progressTrack = document.querySelector('[role="progressbar"]') as HTMLElement;
  const backBtn = document.getElementById('backBtn') as HTMLButtonElement;
  const nextBtn = document.getElementById('nextBtn') as HTMLButtonElement;

  function getStepEl(n: number) {
    return document.querySelector<HTMLElement>(`.step[data-step="${n}"]`);
  }

  function getGrid(n: number) {
    return getStepEl(n)?.querySelector<HTMLElement>('[data-question]');
  }

  function getQuestionKey(n: number): string {
    return getGrid(n)?.dataset.question ?? '';
  }

  function hasAnswer(n: number): boolean {
    const key = getQuestionKey(n);
    const val = answers[key];
    if (Array.isArray(val)) return val.length > 0;
    return typeof val === 'string' && val.length > 0;
  }

  function updateProgress() {
    const pct = Math.round(((currentStep - 1) / TOTAL_STEPS) * 100);
    progressFill.style.width = `${pct}%`;
    progressTrack?.setAttribute('aria-valuenow', String(pct));
    progressLabel.textContent = `Question ${currentStep} of ${TOTAL_STEPS}`;
  }

  function showStep(n: number, scrollUp = true) {
    document.querySelectorAll<HTMLElement>('.step').forEach((el) => { el.hidden = true; });
    const el = getStepEl(n);
    if (el) el.hidden = false;

    updateProgress();
    backBtn.hidden = n === 1;
    nextBtn.disabled = !hasAnswer(n);
    nextBtn.textContent = n === TOTAL_STEPS ? 'See My Results →' : 'Continue →';

    if (scrollUp) {
      requestAnimationFrame(() => {
        document.querySelector('.survey-body')?.scrollIntoView({ behavior: 'smooth', block: 'nearest' });
      });
    }
  }

  function goNext() {
    if (advancing || !hasAnswer(currentStep)) return;

    if (currentStep === TOTAL_STEPS) {
      const score = calculateRiskScore(answers as never);
      const tier = getRecommendedTier(score);
      const profileData = {
        ...answers,
        riskScore: score,
        recommendedTier: tier,
        completedAt: new Date().toISOString(),
      };
      sessionStorage.setItem('profileData', JSON.stringify(profileData));
      window.location.href = '/recommendations/';
      return;
    }

    currentStep++;
    showStep(currentStep);
  }

  function goBack() {
    if (currentStep <= 1) return;
    currentStep--;
    showStep(currentStep);
  }

  nextBtn.addEventListener('click', goNext);
  backBtn.addEventListener('click', goBack);

  document.querySelectorAll<HTMLElement>('.option-grid').forEach((grid) => {
    const isMulti = grid.dataset.multiselect === 'true';
    const key = grid.dataset.question ?? '';

    grid.querySelectorAll<HTMLElement>('.option-btn').forEach((btn) => {
      btn.addEventListener('click', () => {
        if (isMulti) {
          btn.classList.toggle('selected');
          answers[key] = [...grid.querySelectorAll<HTMLElement>('.option-btn.selected')]
            .map((b) => b.dataset.value ?? '');
          nextBtn.disabled = (answers[key] as string[]).length === 0;
        } else {
          grid.querySelectorAll('.option-btn').forEach((b) => b.classList.remove('selected'));
          btn.classList.add('selected');
          answers[key] = btn.dataset.value ?? '';
          nextBtn.disabled = false;

          // Auto-advance single-select after brief visual feedback
          advancing = true;
          setTimeout(() => {
            advancing = false;
            goNext();
          }, 360);
        }
      });
    });
  });

  showStep(1, false);
</script>

<style>
  .survey-hero {
    padding: 64px 0 32px;
    background: radial-gradient(circle at top right, #FFE4C7, transparent 34%), var(--color-cream);
  }
  .survey-hero-inner {
    max-width: 820px;
  }
  .survey-hero h1 {
    font-size: clamp(2.2rem, 6vw, 4rem);
    max-width: 760px;
  }

  .survey-body {
    padding: 0 0 80px;
    background: var(--color-cream);
  }
  .survey-container {
    max-width: 720px;
    padding-top: 32px;
  }

  /* Progress */
  .progress-track {
    height: 6px;
    background: var(--color-gray-100);
    border-radius: 99px;
    overflow: hidden;
  }
  .progress-fill {
    height: 100%;
    background: var(--color-orange);
    border-radius: 99px;
    transition: width 0.35s ease;
    width: 0%;
  }
  .progress-label {
    font-size: .82rem;
    font-weight: 800;
    color: var(--color-gray-600);
    text-transform: uppercase;
    letter-spacing: .07em;
    margin: 10px 0 28px;
  }

  /* Steps */
  .steps-container {
    min-height: 320px;
  }
  .step { animation: stepIn .22s ease both; }
  @keyframes stepIn {
    from { opacity: 0; transform: translateY(10px); }
    to   { opacity: 1; transform: translateY(0); }
  }

  .q-heading {
    font-size: clamp(1.45rem, 4vw, 2.2rem);
    margin-bottom: 8px;
  }
  .q-sub {
    color: var(--color-gray-700);
    font-size: .97rem;
    margin-bottom: 20px;
  }

  /* Option grid layouts */
  .option-grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 10px;
    margin-top: 18px;
  }
  .option-grid-wrap {
    grid-template-columns: repeat(2, 1fr);
  }
  .option-grid-two {
    grid-template-columns: repeat(2, 1fr);
    max-width: 420px;
  }
  .option-grid-three {
    grid-template-columns: repeat(3, 1fr);
  }

  /* Option buttons */
  .option-btn {
    position: relative;
    display: flex;
    flex-direction: column;
    align-items: flex-start;
    text-align: left;
    background: var(--color-white);
    border: 2px solid var(--color-gray-100);
    border-radius: 16px;
    padding: 14px 18px;
    font: inherit;
    font-size: .97rem;
    font-weight: 800;
    color: var(--color-navy);
    cursor: pointer;
    transition: border-color .12s, background .12s, transform .08s;
    touch-action: manipulation;
    min-height: 52px;
  }
  .option-btn:hover {
    border-color: rgba(249, 115, 22, .45);
    background: rgba(249, 115, 22, .03);
  }
  .option-btn.selected {
    border-color: var(--color-orange);
    background: rgba(249, 115, 22, .06);
  }
  .option-btn.selected::after {
    content: '✓';
    position: absolute;
    top: 8px;
    right: 10px;
    width: 20px;
    height: 20px;
    background: var(--color-orange);
    color: var(--color-white);
    border-radius: 50%;
    display: grid;
    place-items: center;
    font-size: .72rem;
    font-weight: 950;
    line-height: 1;
  }
  .option-btn-lg {
    justify-content: center;
    align-items: center;
    font-size: 1.1rem;
    padding: 22px 18px;
  }
  .option-btn-rich strong {
    display: block;
    font-size: .97rem;
    font-weight: 900;
    color: var(--color-navy);
    margin-bottom: 4px;
  }
  .option-btn-rich span {
    display: block;
    font-size: .84rem;
    font-weight: 600;
    color: var(--color-gray-700);
    line-height: 1.35;
  }

  /* Navigation */
  .survey-nav {
    display: flex;
    align-items: center;
    justify-content: space-between;
    margin-top: 28px;
    gap: 14px;
  }
  .nav-back {
    background: none;
    border: none;
    font: inherit;
    font-weight: 800;
    color: var(--color-gray-600);
    cursor: pointer;
    padding: 12px 0;
    font-size: .95rem;
  }
  .nav-back:hover { color: var(--color-navy); }
  .nav-continue {
    margin-left: auto;
    background: var(--color-orange);
    border: none;
    border-radius: 999px;
    color: var(--color-white);
    font: inherit;
    font-weight: 950;
    font-size: 1rem;
    padding: 14px 28px;
    cursor: pointer;
    transition: filter .1s, opacity .1s;
  }
  .nav-continue:hover:not(:disabled) { filter: brightness(.94); }
  .nav-continue:disabled {
    opacity: .45;
    cursor: not-allowed;
  }

  @media (max-width: 620px) {
    .option-grid,
    .option-grid-wrap,
    .option-grid-three {
      grid-template-columns: 1fr;
    }
    .option-grid-two {
      grid-template-columns: repeat(2, 1fr);
      max-width: 100%;
    }
    .nav-continue { width: 100%; }
    .survey-nav { flex-wrap: wrap; }
    .nav-back { order: 2; margin: 0 auto; }
  }
</style>
