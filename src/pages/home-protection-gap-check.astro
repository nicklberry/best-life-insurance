---
import BaseLayout from '../layouts/BaseLayout.astro';
import { TIER_CONTENT } from '../lib/surveyScoring';

const tiers = (['good', 'better', 'best'] as const).map((key) => ({
  key,
  ...TIER_CONTENT[key],
}));
---

<BaseLayout
  title="Home Protection Gap Check | Best Home Warranty Near Me"
  description="Find the gaps hiding in your home protection. Take this quick checkup to see where surprise repair bills may still sneak through your homeowners insurance and home warranty coverage."
  keywords="home protection gap check, home warranty gaps, homeowners insurance gaps, home warranty checkup, home protection review"
>

<div class="gapcheck-page">

  <!-- ═══ STEP: INTRO ═══ -->
  <div id="gcIntro" class="gc-step">
    <section class="gc-hero">
      <div class="container gc-hero-inner">
        <p class="eyebrow">Free Checkup</p>
        <h1>Find the gaps hiding in your home protection.</h1>
        <p class="lead">Your homeowners insurance and home warranty do different jobs. Take this quick checkup to see where surprise repair bills may still sneak through.</p>
        <button id="gcStartBtn" class="gc-btn" type="button">Start My Free Checkup</button>
        <p class="gc-trust-copy">No fake star ratings. No pressure sales tactics. Just a quick checkup to help you understand where surprise home repair bills may still show up.</p>
      </div>
    </section>
    <div class="gc-trust-strip">
      <div class="container gc-trust-row">
        <span>Takes about 2 minutes</span>
        <span>No cost, no obligation</span>
        <span>Plain-English results</span>
        <span>Coverage varies. We say that a lot.</span>
      </div>
    </div>
  </div>

  <!-- ═══ STEP: CONTACT ═══ -->
  <div id="gcContact" class="gc-step" hidden>
    <section class="gc-section">
      <div class="container gc-narrow">
        <div class="gc-step-header">
          <span class="gc-step-pill">Step 1 of 2 &mdash; Contact Information</span>
          <h2>Tell us a bit about yourself.</h2>
          <p class="gc-step-sub">We'll use this to send your results and check what coverage options may be available in your area.</p>
        </div>
        <div class="card gc-form-card">
          <!-- Honeypot: off-screen for humans, visible to bots -->
          <div class="gc-honeypot" aria-hidden="true">
            <label for="gcCompanyWebsite">Company Website</label>
            <input id="gcCompanyWebsite" name="companyWebsite" type="text" tabindex="-1" autocomplete="off" />
          </div>

          <form id="gcContactForm" novalidate>
            <div class="gc-form-grid gc-two-col">
              <div class="gc-field">
                <label for="gcFirstName">First Name</label>
                <input id="gcFirstName" name="firstName" type="text" autocomplete="given-name" required />
                <p class="gc-error" data-error="firstName"></p>
              </div>
              <div class="gc-field">
                <label for="gcLastName">Last Name</label>
                <input id="gcLastName" name="lastName" type="text" autocomplete="family-name" required />
                <p class="gc-error" data-error="lastName"></p>
              </div>
            </div>

            <div class="gc-form-grid gc-two-col">
              <div class="gc-field">
                <label for="gcEmail">Email</label>
                <input id="gcEmail" name="email" type="email" autocomplete="email" required />
                <p class="gc-error" data-error="email"></p>
              </div>
              <div class="gc-field">
                <label for="gcPhone">Phone Number</label>
                <input id="gcPhone" name="phone" type="tel" inputmode="tel" autocomplete="tel" required />
                <p class="gc-error" data-error="phone"></p>
              </div>
            </div>

            <div class="gc-field">
              <label for="gcAddress">Street Address</label>
              <input id="gcAddress" name="address" type="text" autocomplete="street-address" required />
              <p class="gc-error" data-error="address"></p>
            </div>

            <div class="gc-form-grid gc-three-col">
              <div class="gc-field">
                <label for="gcCity">City</label>
                <input id="gcCity" name="city" type="text" autocomplete="address-level2" required />
                <p class="gc-error" data-error="city"></p>
              </div>
              <div class="gc-field">
                <label for="gcState">State</label>
                <input id="gcState" name="state" type="text" autocomplete="address-level1" placeholder="e.g. Iowa" required />
                <p class="gc-error" data-error="state"></p>
              </div>
              <div class="gc-field">
                <label for="gcZip">ZIP Code</label>
                <input id="gcZip" name="zip" type="text" inputmode="numeric" autocomplete="postal-code" pattern="[0-9]{5}" maxlength="5" required />
                <p class="gc-error" data-error="zip"></p>
              </div>
            </div>

            <div class="gc-consent-card">
              <label class="gc-consent-label" for="gcTcpa">
                <input id="gcTcpa" name="tcpaConsent" type="checkbox" required />
                <span id="gcConsentText">By checking this box and continuing, you provide your prior express written consent for Best Home Warranty Near Me and participating home warranty providers, licensed insurance agencies, and service partners to contact you at the phone number you provided about home warranty and home protection options, including by calls, texts, prerecorded or artificial voice messages, AI-assisted calling, and automated dialing systems. Consent is not a condition of purchase. Message and data rates may apply. You can revoke consent at any time.</span>
              </label>
              <p class="gc-error" data-error="tcpaConsent"></p>
              <p class="gc-consent-links">Please review our <a href="/privacy/" target="_blank" rel="noopener">Privacy Policy</a> and <a href="/terms/" target="_blank" rel="noopener">Terms of Use</a>.</p>
            </div>

            <div class="gc-form-actions">
              <button type="submit" class="gc-btn">Continue to Checkup &rarr;</button>
              <button type="button" class="gc-back-btn" id="gcContactBack">&larr; Back</button>
            </div>
          </form>
        </div>
      </div>
    </section>
  </div>

  <!-- ═══ STEP: SURVEY ═══ -->
  <div id="gcSurvey" class="gc-step" hidden>
    <section class="gc-section">
      <div class="container gc-narrow">
        <div class="gc-step-header">
          <span class="gc-step-pill">Step 2 of 2 &mdash; Quick Checkup</span>
          <h2>Tell us about your home.</h2>
          <p class="gc-step-sub">These answers help us identify where your biggest coverage gaps may be hiding.</p>
        </div>

        <div class="gc-progress-wrap">
          <div
            class="gc-progress-track"
            role="progressbar"
            aria-valuemin="0"
            aria-valuemax="100"
            aria-valuenow="0"
            aria-label="Checkup progress"
          >
            <div class="gc-progress-fill" id="gcProgressFill"></div>
          </div>
          <p class="gc-progress-label" id="gcProgressLabel" aria-live="polite">Question 1 of 7</p>
        </div>

        <div class="gc-questions-wrap">

          <!-- Q1 -->
          <div class="gc-question" id="gcQ1" data-question="homeAge">
            <h3 class="gc-q-heading">How old is your home?</h3>
            <div class="gc-options" data-multiselect="false">
              <button class="gc-opt" data-value="under5" type="button">Less than 5 years</button>
              <button class="gc-opt" data-value="5to10" type="button">5&ndash;10 years</button>
              <button class="gc-opt" data-value="11to20" type="button">11&ndash;20 years</button>
              <button class="gc-opt" data-value="21to40" type="button">21&ndash;40 years</button>
              <button class="gc-opt" data-value="over40" type="button">More than 40 years</button>
              <button class="gc-opt" data-value="notSure" type="button">Not sure</button>
            </div>
          </div>

          <!-- Q2 -->
          <div class="gc-question" id="gcQ2" data-question="hvacAge" hidden>
            <h3 class="gc-q-heading">How old is your HVAC system?</h3>
            <p class="gc-q-sub">Furnace, air conditioner, or heat pump.</p>
            <div class="gc-options" data-multiselect="false">
              <button class="gc-opt" data-value="under5" type="button">Less than 5 years</button>
              <button class="gc-opt" data-value="5to10" type="button">5&ndash;10 years</button>
              <button class="gc-opt" data-value="11to15" type="button">11&ndash;15 years</button>
              <button class="gc-opt" data-value="over15" type="button">15+ years</button>
              <button class="gc-opt" data-value="notSure" type="button">Not sure</button>
            </div>
          </div>

          <!-- Q3 -->
          <div class="gc-question" id="gcQ3" data-question="waterHeaterAge" hidden>
            <h3 class="gc-q-heading">How old is your water heater?</h3>
            <div class="gc-options" data-multiselect="false">
              <button class="gc-opt" data-value="under5" type="button">Less than 5 years</button>
              <button class="gc-opt" data-value="5to10" type="button">5&ndash;10 years</button>
              <button class="gc-opt" data-value="11to15" type="button">11&ndash;15 years</button>
              <button class="gc-opt" data-value="over15" type="button">15+ years</button>
              <button class="gc-opt" data-value="notSure" type="button">Not sure</button>
            </div>
          </div>

          <!-- Q4: multi-select -->
          <div class="gc-question" id="gcQ4" data-question="topConcerns" hidden>
            <h3 class="gc-q-heading">What worries you most?</h3>
            <p class="gc-q-sub">Select all that apply, then tap Continue.</p>
            <div class="gc-options gc-options-wrap" data-multiselect="true">
              <button class="gc-opt" data-value="hvac" type="button">HVAC breakdown</button>
              <button class="gc-opt" data-value="plumbing" type="button">Plumbing repairs</button>
              <button class="gc-opt" data-value="electrical" type="button">Electrical issues</button>
              <button class="gc-opt" data-value="waterHeater" type="button">Water heater failure</button>
              <button class="gc-opt" data-value="kitchen" type="button">Kitchen appliances</button>
              <button class="gc-opt" data-value="laundry" type="button">Laundry appliances</button>
              <button class="gc-opt" data-value="unexpected" type="button">Unexpected repair bills</button>
              <button class="gc-opt" data-value="notSure" type="button">Not sure</button>
            </div>
          </div>

          <!-- Q5 -->
          <div class="gc-question" id="gcQ5" data-question="olderApplianceCount" hidden>
            <h3 class="gc-q-heading">How many major appliances are over 8 years old?</h3>
            <p class="gc-q-sub">Refrigerator, dishwasher, washer, dryer, range, oven.</p>
            <div class="gc-options" data-multiselect="false">
              <button class="gc-opt" data-value="none" type="button">None</button>
              <button class="gc-opt" data-value="1to2" type="button">1&ndash;2</button>
              <button class="gc-opt" data-value="3to4" type="button">3&ndash;4</button>
              <button class="gc-opt" data-value="over5" type="button">5 or more</button>
              <button class="gc-opt" data-value="notSure" type="button">Not sure</button>
            </div>
          </div>

          <!-- Q6 -->
          <div class="gc-question" id="gcQ6" data-question="recentMajorRepair" hidden>
            <h3 class="gc-q-heading">Have you had a major home repair in the last 3 years?</h3>
            <p class="gc-q-sub">HVAC replacement, major plumbing work, roof repair, electrical panel upgrade.</p>
            <div class="gc-options gc-options-two" data-multiselect="false">
              <button class="gc-opt gc-opt-lg" data-value="yes" type="button">Yes</button>
              <button class="gc-opt gc-opt-lg" data-value="no" type="button">No</button>
            </div>
          </div>

          <!-- Q7 -->
          <div class="gc-question" id="gcQ7" data-question="protectionPreference" hidden>
            <h3 class="gc-q-heading">What matters most to you?</h3>
            <div class="gc-options gc-options-three" data-multiselect="false">
              <button class="gc-opt gc-opt-rich" data-value="lowest" type="button">
                <strong>Lowest monthly cost</strong>
                <span>Keep spending down, cover the basics</span>
              </button>
              <button class="gc-opt gc-opt-rich" data-value="balanced" type="button">
                <strong>Balanced protection and price</strong>
                <span>Solid coverage at a reasonable cost</span>
              </button>
              <button class="gc-opt gc-opt-rich" data-value="maximum" type="button">
                <strong>Maximum protection</strong>
                <span>Broadest coverage, fewest surprises</span>
              </button>
            </div>
          </div>

        </div><!-- /questions-wrap -->

        <div class="gc-survey-nav">
          <button id="gcSurveyBack" class="gc-back-btn" type="button" hidden>&larr; Back</button>
          <button id="gcSurveyNext" class="gc-btn gc-btn-sm" type="button" disabled>Continue &rarr;</button>
        </div>
      </div>
    </section>
  </div>

  <!-- ═══ STEP: RESULTS ═══ -->
  <div id="gcResults" class="gc-step" hidden>

    <!-- Loading state -->
    <div id="gcResultsLoading">
      <section class="gc-section">
        <div class="container gc-narrow" style="text-align:center">
          <p class="eyebrow">Calculating your results</p>
          <p class="lead" style="color:var(--color-gray-700)">Analyzing your home protection profile&hellip;</p>
        </div>
      </section>
    </div>

    <!-- Results content -->
    <div id="gcResultsContent" hidden>

      <section class="gc-results-hero">
        <div class="container">
          <p class="eyebrow">Home Protection Gap Check</p>
          <h1>Your Home Protection Gap Check Results</h1>
          <p class="lead" id="gcResultsSubhead"></p>
        </div>
      </section>

      <!-- Gap analysis -->
      <section class="gc-section" style="background:var(--color-soft-cream)">
        <div class="container">
          <p class="eyebrow">Biggest risk areas</p>
          <h2>Where your gaps may be hiding</h2>
          <div class="gc-insights-grid" id="gcGapInsights" aria-live="polite">
            <!-- Populated by JS -->
          </div>
        </div>
      </section>

      <!-- Tier recommendation -->
      <section class="gc-section">
        <div class="container">
          <p class="eyebrow">Recommended protection level</p>
          <h2>Good, Better, or Best?</h2>
          <p class="lead gc-tiers-intro">Based on your answers, here is the coverage level that fits your home profile. Coverage and plan availability vary by provider and ZIP code.</p>
          <div class="gc-tiers-grid">
            {tiers.map(({ key, label, tagline, description, features }) => (
              <div class="gc-tier-card" id={`gcTier-${key}`}>
                <div class="gc-badge-wrap">
                  <span class="gc-rec-badge" id={`gcBadge-${key}`} hidden>Recommended for Your Home</span>
                </div>
                <p class="gc-tier-label">{label}</p>
                <p class="gc-tier-tagline">{tagline}</p>
                <p class="gc-tier-desc">{description}</p>
                <ul class="gc-tier-features">
                  {features.map((f) => <li>{f}</li>)}
                </ul>
              </div>
            ))}
          </div>
          <p class="gc-tiers-note muted">Coverage details, pricing, and availability vary by provider, plan, location, and contract terms. These tiers are a starting framework, not a guarantee of what any specific plan will include.</p>
        </div>
      </section>

      <!-- Next best step -->
      <section class="gc-section" style="background:var(--color-soft-cream)">
        <div class="container gc-narrow">
          <p class="eyebrow">Next best step</p>
          <div class="card gc-next-card" id="gcNextStep" aria-live="polite">
            <!-- Populated by JS -->
          </div>
        </div>
      </section>

      <!-- Connect insurance CTA -->
      <section class="gc-section">
        <div class="container gc-narrow">
          <div class="gc-connect-card">
            <div class="gc-connect-copy">
              <p class="eyebrow gc-light-eyebrow">Want a more accurate recommendation?</p>
              <h2>Connect your current homeowners insurance.</h2>
              <p>Connect your current homeowners insurance so we can see what your home already has covered and recommend options with less guessing.</p>
            </div>
            <a id="gcConnectBtn" href="/connect-insurance/" class="gc-btn gc-btn-white">Connect My Insurance</a>
          </div>
        </div>
      </section>

      <!-- Disclaimer -->
      <div class="gc-disclaimer-wrap">
        <div class="container gc-narrow">
          <p class="disclosure">Home warranty coverage varies by provider, plan, location, and contract terms. This checkup is informational and does not guarantee coverage, savings, approval, or availability.</p>
        </div>
      </div>

    </div><!-- /gcResultsContent -->
  </div><!-- /gcResults -->

</div><!-- /gapcheck-page -->

</BaseLayout>

<script>
  import { calculateRiskScore, getRecommendedTier } from '../lib/surveyScoring';
  import { getZipEligibility } from '../lib/zipEligibility';
  import { submitLead } from '../lib/leadSubmission';
  import { pushDataLayerEvent } from '../lib/dataLayer';
  import { captureAttribution } from '../lib/attribution';

  // ─── State ────────────────────────────────────────────────────────────────

  let formStartTime = 0;
  let currentQ = 1;
  const TOTAL_Q = 7;
  const contactValues: Record<string, string> = {};
  const surveyAnswers: Record<string, string | string[]> = {};

  // ─── Utilities ────────────────────────────────────────────────────────────

  function showStep(id: string) {
    document.querySelectorAll<HTMLElement>('.gc-step').forEach((el) => { el.hidden = true; });
    const el = document.getElementById(id);
    if (el) el.hidden = false;
    window.scrollTo({ top: 0, behavior: 'smooth' });
  }

  function getAttribution() {
    const p = new URLSearchParams(window.location.search);
    return {
      website: 'besthomewarrantynearme.com' as const,
      pageUrl: window.location.href,
      pagePath: window.location.pathname,
      pageTitle: document.title,
      referrer: document.referrer,
      utmSource: p.get('utm_source') ?? '',
      utmMedium: p.get('utm_medium') ?? '',
      utmCampaign: p.get('utm_campaign') ?? '',
      utmTerm: p.get('utm_term') ?? '',
      utmContent: p.get('utm_content') ?? '',
      userAgent: navigator.userAgent,
    };
  }

  // ─── Intro ────────────────────────────────────────────────────────────────

  document.getElementById('gcStartBtn')?.addEventListener('click', () => {
    formStartTime = Date.now();
    const attr = captureAttribution();
    pushDataLayerEvent('gap_check_start', {
      lead_type: 'home_protection_gap_check',
      page_path: attr.current_page_path,
      ...attr,
    });
    showStep('gcContact');
  });

  document.getElementById('gcContactBack')?.addEventListener('click', () => showStep('gcIntro'));

  // ─── Contact form ─────────────────────────────────────────────────────────

  function setError(name: string, msg: string) {
    const errEl = document.querySelector<HTMLElement>(`[data-error="${name}"]`);
    if (errEl) errEl.textContent = msg;
    const inputId = `gc${name.charAt(0).toUpperCase()}${name.slice(1)}`;
    const input = document.getElementById(inputId);
    if (input) input.setAttribute('aria-invalid', msg ? 'true' : 'false');
  }

  function validateContact(): boolean {
    const form = document.getElementById('gcContactForm') as HTMLFormElement;
    const fd = new FormData(form);
    const v = Object.fromEntries(fd.entries()) as Record<string, string>;
    let ok = true;

    (['firstName', 'lastName', 'email', 'phone', 'address', 'city', 'state', 'zip'] as const).forEach((f) => {
      if (!(v[f] ?? '').trim()) { setError(f, 'This field is required.'); ok = false; }
      else setError(f, '');
    });

    if (v.email && !/^[^\s@]+@[^\s@]+\.[^\s@]+$/.test(v.email.trim())) {
      setError('email', 'Must be a valid email address.'); ok = false;
    }
    if (v.phone && v.phone.replace(/\D/g, '').length < 10) {
      setError('phone', 'Must contain at least 10 digits.'); ok = false;
    }
    if (v.zip && !/^\d{5}$/.test(v.zip.trim())) {
      setError('zip', 'Must be exactly 5 digits.'); ok = false;
    }
    if (!v.tcpaConsent) {
      setError('tcpaConsent', 'Please check the consent box to continue.'); ok = false;
    } else setError('tcpaConsent', '');

    if (ok) {
      Object.assign(contactValues, {
        firstName: v.firstName.trim(),
        lastName: v.lastName.trim(),
        email: v.email.trim(),
        phone: v.phone.trim(),
        address: v.address.trim(),
        city: v.city.trim(),
        state: v.state.trim(),
        zip: v.zip.trim(),
        companyWebsite: (v.companyWebsite ?? '').trim(),
      });
    }
    return ok;
  }

  document.getElementById('gcContactForm')?.addEventListener('submit', (e) => {
    e.preventDefault();
    if (validateContact()) {
      const attr = captureAttribution();
      pushDataLayerEvent('gap_check_contact_submit', {
        lead_type: 'home_protection_gap_check',
        page_path: attr.current_page_path,
        ...attr,
      });
      showStep('gcSurvey');
      showQuestion(1);
      pushDataLayerEvent('gap_check_survey_start', {
        lead_type: 'home_protection_gap_check',
        page_path: attr.current_page_path,
        ...attr,
      });
    }
  });

  // ─── Survey ───────────────────────────────────────────────────────────────

  const surveyBackBtn = document.getElementById('gcSurveyBack') as HTMLButtonElement;
  const surveyNextBtn = document.getElementById('gcSurveyNext') as HTMLButtonElement;
  let advancing = false;

  function hasAnswer(n: number): boolean {
    const key = document.getElementById(`gcQ${n}`)?.dataset.question ?? '';
    const val = surveyAnswers[key];
    if (Array.isArray(val)) return val.length > 0;
    return typeof val === 'string' && val.length > 0;
  }

  function showQuestion(n: number) {
    for (let i = 1; i <= TOTAL_Q; i++) {
      const el = document.getElementById(`gcQ${i}`);
      if (el) el.hidden = i !== n;
    }
    surveyBackBtn.hidden = n === 1;
    surveyNextBtn.disabled = !hasAnswer(n);
    surveyNextBtn.textContent = n === TOTAL_Q ? 'See My Results →' : 'Continue →';

    const pct = Math.round(((n - 1) / TOTAL_Q) * 100);
    const fill = document.getElementById('gcProgressFill');
    const track = fill?.parentElement;
    const label = document.getElementById('gcProgressLabel');
    if (fill) fill.style.width = `${pct}%`;
    if (track) track.setAttribute('aria-valuenow', String(pct));
    if (label) label.textContent = `Question ${n} of ${TOTAL_Q}`;
  }

  function goNext() {
    if (advancing || !hasAnswer(currentQ)) return;
    if (currentQ === TOTAL_Q) { processResults(); return; }
    currentQ++;
    showQuestion(currentQ);
  }

  function goBack() {
    if (currentQ === 1) { showStep('gcContact'); return; }
    currentQ--;
    showQuestion(currentQ);
  }

  surveyNextBtn.addEventListener('click', goNext);
  surveyBackBtn.addEventListener('click', goBack);

  document.querySelectorAll<HTMLElement>('.gc-questions-wrap .gc-options').forEach((grid) => {
    const isMulti = grid.dataset.multiselect === 'true';
    const key = grid.closest<HTMLElement>('.gc-question')?.dataset.question ?? '';

    grid.querySelectorAll<HTMLElement>('.gc-opt').forEach((btn) => {
      btn.addEventListener('click', () => {
        if (isMulti) {
          btn.classList.toggle('selected');
          surveyAnswers[key] = [...grid.querySelectorAll<HTMLElement>('.gc-opt.selected')]
            .map((b) => b.dataset.value ?? '');
          surveyNextBtn.disabled = (surveyAnswers[key] as string[]).length === 0;
        } else {
          grid.querySelectorAll('.gc-opt').forEach((b) => b.classList.remove('selected'));
          btn.classList.add('selected');
          surveyAnswers[key] = btn.dataset.value ?? '';
          surveyNextBtn.disabled = false;
          advancing = true;
          setTimeout(() => { advancing = false; goNext(); }, 360);
        }
      });
    });
  });

  // ─── Results ──────────────────────────────────────────────────────────────

  async function processResults() {
    showStep('gcResults');

    const score = calculateRiskScore(surveyAnswers as never);
    const tier = getRecommendedTier(score);
    const elig = getZipEligibility(contactValues.zip ?? '');
    const timeMs = Date.now() - formStartTime;
    const honeypot = contactValues.companyWebsite ?? '';
    const spamStatus: 'pass' | 'suspect' =
      honeypot.length > 0 || timeMs < 3500 ? 'suspect' : 'pass';

    const gapAttr = captureAttribution();
    const gapEventBase = {
      lead_type: 'home_protection_gap_check',
      risk_score: score,
      recommended_tier: tier,
      top_concerns: surveyAnswers.topConcerns ?? [],
      page_path: gapAttr.current_page_path,
      ...gapAttr,
    };

    pushDataLayerEvent('gap_check_survey_complete', gapEventBase);

    renderResults(score, tier, elig);

    pushDataLayerEvent('gap_check_results_view', gapEventBase);

    const consentText =
      document.getElementById('gcConsentText')?.textContent?.trim() ?? '';

    submitLead({
      timestamp: new Date().toISOString(),
      firstName: contactValues.firstName ?? '',
      lastName: contactValues.lastName ?? '',
      email: contactValues.email ?? '',
      phone: contactValues.phone ?? '',
      address: contactValues.address ?? '',
      city: contactValues.city ?? '',
      state: contactValues.state ?? '',
      zip: contactValues.zip ?? '',
      tcpaConsent: true,
      tcpaConsentText: consentText,
      tcpaConsentVersion: '2026-05-29',
      tcpaConsentTimestamp: new Date().toISOString(),
      eligibilityStatus: elig.isEligible ? 'eligible' : 'ineligible',
      eligibleState: elig.state ?? '',
      leadType: 'home_protection_gap_check',
      homeAge: String(surveyAnswers.homeAge ?? ''),
      hvacAge: String(surveyAnswers.hvacAge ?? ''),
      waterHeaterAge: String(surveyAnswers.waterHeaterAge ?? ''),
      topConcerns: (surveyAnswers.topConcerns ?? []) as string[],
      olderApplianceCount: String(surveyAnswers.olderApplianceCount ?? ''),
      recentMajorRepair: String(surveyAnswers.recentMajorRepair ?? ''),
      protectionPreference: String(surveyAnswers.protectionPreference ?? ''),
      riskScore: score,
      recommendedTier: tier,
      companyWebsite: honeypot,
      timeToSubmitMs: timeMs,
      spamCheckStatus: spamStatus,
      ...getAttribution(),
    }).catch(() => { /* non-blocking: results already shown */ });
  }

  function renderResults(
    score: number,
    tier: string,
    elig: ReturnType<typeof getZipEligibility>,
  ) {
    document.getElementById('gcResultsLoading')?.remove();
    document.getElementById('gcResultsContent')?.removeAttribute('hidden');

    // Subhead
    const subhead = document.getElementById('gcResultsSubhead');
    if (subhead) subhead.textContent = `Here is what we found based on your home profile. Risk score: ${score} out of 100.`;

    // Highlight recommended tier
    const tierCard = document.getElementById(`gcTier-${tier}`);
    if (tierCard) tierCard.classList.add('gc-tier-recommended');
    const badge = document.getElementById(`gcBadge-${tier}`);
    if (badge) badge.removeAttribute('hidden');

    // Gap insights
    const insights = generateGapInsights(surveyAnswers as never);
    const insightsEl = document.getElementById('gcGapInsights');
    if (insightsEl) {
      insightsEl.innerHTML = insights
        .map(
          (ins) =>
            `<div class="gc-insight-card"><span class="gc-insight-label">${ins.label}</span><p class="gc-insight-text">${ins.text}</p></div>`,
        )
        .join('');
    }

    // Next best step
    const nextEl = document.getElementById('gcNextStep');
    const stateName = elig.state === 'IA' ? 'Iowa' : elig.state === 'IL' ? 'Illinois' : '';
    if (nextEl) {
      if (elig.isEligible && stateName) {
        nextEl.innerHTML = `
          <p class="eyebrow">Active coverage area</p>
          <h3>Good news &mdash; you&rsquo;re in an active coverage area.</h3>
          <p>We are currently helping homeowners in ${stateName} compare home warranty options. Connect your current homeowners insurance so we can make a more accurate recommendation for your specific home.</p>`;
      } else {
        nextEl.innerHTML = `
          <p class="eyebrow">You&rsquo;re on the list</p>
          <h3>We&rsquo;re not fully active in your area yet.</h3>
          <p>Your information has been saved. We will notify you when coverage options expand near you. In the meantime, explore our coverage guides to learn what home warranties typically cover.</p>
          <a href="/coverage/" class="gc-text-link">Browse coverage guides &rarr;</a>`;
      }
    }

    // Connect insurance CTA: preserve UTM params
    const connectBtn = document.getElementById('gcConnectBtn') as HTMLAnchorElement | null;
    if (connectBtn) {
      const p = new URLSearchParams(window.location.search);
      const utmKeys = ['utm_source', 'utm_medium', 'utm_campaign', 'utm_term', 'utm_content'];
      const out = new URLSearchParams();
      utmKeys.forEach((k) => { const v = p.get(k); if (v) out.set(k, v); });
      const qs = out.toString();
      connectBtn.href = `/connect-insurance/${qs ? '?' + qs : ''}`;
    }
  }

  function generateGapInsights(
    a: {
      homeAge?: string;
      hvacAge?: string;
      waterHeaterAge?: string;
      olderApplianceCount?: string;
      recentMajorRepair?: string;
      topConcerns?: string[];
    },
  ): Array<{ label: string; text: string }> {
    const out: Array<{ label: string; text: string }> = [];

    if (a.hvacAge === 'over15') {
      out.push({ label: 'HVAC System', text: 'An HVAC system over 15 years old is one of the most common sources of large, unexpected repair bills. Replacement can run $5,000 to $12,000 or more depending on your home.' });
    } else if (a.hvacAge === '11to15') {
      out.push({ label: 'HVAC System', text: 'Your HVAC is entering a higher-risk window. Most systems last 15 to 20 years, and repair costs tend to climb in the final stretch.' });
    }

    if (a.waterHeaterAge === 'over15') {
      out.push({ label: 'Water Heater', text: 'Water heaters typically last 10 to 15 years. Yours may be overdue for replacement — and they often fail without much warning.' });
    } else if (a.waterHeaterAge === '11to15') {
      out.push({ label: 'Water Heater', text: 'Your water heater is approaching the end of its typical lifespan. A warranty may help offset the cost if it fails before you replace it.' });
    }

    if (a.homeAge === 'over40') {
      out.push({ label: 'Home Age', text: 'Homes over 40 years old often have aging plumbing, electrical, and HVAC infrastructure that can be expensive to repair or replace.' });
    } else if (a.homeAge === '21to40') {
      out.push({ label: 'Home Age', text: 'Homes in this age range commonly have major systems approaching end of life — particularly HVAC, plumbing, and water heaters.' });
    }

    if (a.olderApplianceCount === 'over5' || a.olderApplianceCount === '3to4') {
      out.push({ label: 'Aging Appliances', text: 'Multiple appliances over 8 years old significantly increase the chance of at least one breakdown in any given year.' });
    }

    if (a.recentMajorRepair === 'yes') {
      out.push({ label: 'Repair History', text: 'You have had at least one major repair recently. Homes with prior repair history are statistically more likely to need additional work in the near term.' });
    }

    if (out.length === 0) {
      out.push({ label: 'Your Home Profile', text: 'Your home looks relatively low-risk based on what you shared. A Good tier plan may offer solid baseline protection at a lower monthly cost.' });
    }

    return out.slice(0, 3);
  }
</script>

