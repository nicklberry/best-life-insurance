---
import BaseLayout from '../layouts/BaseLayout.astro';
import CTASection from '../components/CTASection.astro';
import Disclaimer from '../components/Disclaimer.astro';

const comparisons = [
  {
    title: "Term Life vs. Whole Life",
    slug: "term-vs-whole-life",
    cols: ["Term Life", "Whole Life"],
    rows: [
      { label: "Duration", a: "Fixed period (10, 20, 30 years)", b: "Lifetime" },
      { label: "Monthly premiums", a: "Lower", b: "Higher" },
      { label: "Cash value", a: "None", b: "Yes, grows over time" },
      { label: "Death benefit certainty", a: "Only if death occurs during term", b: "Guaranteed (premiums current)" },
      { label: "Best for", a: "Income replacement during key years", b: "Permanent needs, estate planning" },
    ]
  },
  {
    title: "Whole Life vs. Universal Life",
    slug: "whole-vs-universal-life",
    cols: ["Whole Life", "Universal Life"],
    rows: [
      { label: "Premium flexibility", a: "Fixed — same every payment", b: "Flexible within policy limits" },
      { label: "Cash value growth", a: "Guaranteed fixed rate", b: "Tied to interest rates (with floor)" },
      { label: "Death benefit adjustment", a: "Generally fixed", b: "Can be adjusted (underwriting may apply)" },
      { label: "Lapse risk", a: "Lower — premiums are designed to keep policy in force", b: "Higher — insufficient payments can deplete cash value" },
      { label: "Complexity", a: "More predictable", b: "More flexible but more complex" },
    ]
  },
  {
    title: "Life Insurance vs. Mortgage Protection Insurance",
    slug: "life-vs-mortgage-protection",
    cols: ["Term Life Insurance", "Mortgage Protection Insurance"],
    rows: [
      { label: "Death benefit", a: "Level — stays constant throughout term", b: "Decreasing — shrinks as mortgage balance decreases" },
      { label: "Payout goes to", a: "Your beneficiaries (any use)", b: "Often the lender directly" },
      { label: "Flexibility", a: "Funds can cover any need", b: "Tied to mortgage payoff" },
      { label: "Cost per dollar of coverage", a: "Generally lower", b: "Generally higher" },
      { label: "Underwriting", a: "Full medical underwriting typical", b: "Simplified in many programs" },
    ]
  },
  {
    title: "Employer Coverage vs. Individual Coverage",
    slug: "employer-vs-individual-coverage",
    cols: ["Employer Group Life", "Individual Life Insurance"],
    rows: [
      { label: "Coverage amount", a: "Typically 1–2× salary", b: "Any amount you select" },
      { label: "Portability", a: "Ends if you leave the job", b: "Stays with you regardless of employment" },
      { label: "Premium paid by", a: "Employer often pays (or subsidizes)", b: "You pay the premium" },
      { label: "Customization", a: "Limited to employer's group plan", b: "Full selection of policy type and amount" },
      { label: "Medical underwriting", a: "Usually none required", b: "Typically required for standard policies" },
    ]
  }
];
---
<BaseLayout title="Compare Life Insurance Options | Best Life Insurance Near Me" description="Side-by-side comparisons of term vs. whole life, employer vs. individual coverage, mortgage protection vs. life insurance, and more.">
  <section class="page-hero">
    <div class="container">
      <p class="eyebrow">Compare options</p>
      <h1>Life insurance comparisons, side by side.</h1>
      <p class="lead">Understanding the differences between policy types helps you make a more informed decision. No pressure, no fake urgency.</p>
    </div>
  </section>

  <section class="section">
    <div class="container">
      {comparisons.map((comp) => (
        <div class="compare-block" id={comp.slug}>
          <h2>{comp.title}</h2>
          <div class="compare-table-wrap">
            <table class="compare-table">
              <thead>
                <tr>
                  <th>Feature</th>
                  {comp.cols.map((col) => <th>{col}</th>)}
                </tr>
              </thead>
              <tbody>
                {comp.rows.map((row) => (
                  <tr>
                    <td class="row-label">{row.label}</td>
                    <td>{row.a}</td>
                    <td>{row.b}</td>
                  </tr>
                ))}
              </tbody>
            </table>
          </div>
        </div>
      ))}
    </div>
  </section>

  <section class="section" style="background:var(--color-soft-cream)">
    <div class="container narrow">
      <p class="eyebrow">Quick reference</p>
      <h2>Where to start</h2>
      <ul class="list-check">
        <li>If you have dependents and a mortgage, <strong>term life insurance</strong> is the most common starting point.</li>
        <li>If you want permanent coverage for estate planning purposes, <strong>whole life or universal life</strong> may be worth exploring.</li>
        <li>If you only have employer coverage, consider whether that coverage is enough — and whether it would follow you if you changed jobs.</li>
        <li>If you're older and primarily concerned about final expenses, <strong>final expense insurance</strong> is designed for that purpose.</li>
      </ul>
      <Disclaimer />
    </div>
  </section>

  <CTASection />
</BaseLayout>

<style>
  .page-hero { padding: 64px 0 42px; background: linear-gradient(135deg, #EBF0FA 0%, #FFFFFF 60%); }
  .compare-block { margin-bottom: 56px; }
  .compare-block h2 { font-size: clamp(1.6rem, 4vw, 2.6rem); margin-bottom: 20px; }
  .compare-table-wrap { overflow-x: auto; }
  .compare-table { width: 100%; border-collapse: collapse; font-size: .95rem; }
  .compare-table th { background: var(--color-navy); color: white; padding: 12px 16px; text-align: left; font-weight: 900; }
  .compare-table td { padding: 12px 16px; border-bottom: 1px solid rgba(31,41,55,.08); vertical-align: top; line-height: 1.5; }
  .compare-table tr:hover td { background: var(--color-soft-cream); }
  .row-label { font-weight: 900; color: var(--color-navy); width: 28%; }
  .narrow { max-width: 820px; }
</style>
