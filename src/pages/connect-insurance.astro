---
import BaseLayout from '../layouts/BaseLayout.astro';

const trustPoints = [
  {
    icon: '🔒',
    title: 'Secure Connection',
    desc: 'Information is transmitted through encrypted connections.'
  },
  {
    icon: '✋',
    title: 'You Stay In Control',
    desc: 'You choose what information to connect and can stop the process at any time.'
  },
  {
    icon: '🚫',
    title: 'No Password Storage',
    desc: 'We do not store your insurance account passwords.'
  },
  {
    icon: '📋',
    title: 'Used To Improve Recommendations',
    desc: 'Connected information helps us understand your current protection and reduce unnecessary guesswork.'
  }
];

const faqs = [
  {
    question: 'Why are you asking for my insurance information?',
    answer: 'Many people already have protections in place through life insurance policies, employer benefits, homeowners insurance, auto insurance, or other financial products. By understanding what protections may already exist, we can provide more relevant guidance and help identify potential coverage gaps.'
  },
  {
    question: 'Will connecting my information change my existing policies?',
    answer: 'No. Connecting your information does not change, cancel, or modify any of your existing insurance policies. It simply helps us review what protection you already have so we can make better recommendations.'
  },
  {
    question: 'Does this guarantee better coverage or savings?',
    answer: 'No. It helps us make more relevant recommendations, but it does not guarantee coverage, savings, approval, or availability. Available information depends on what you choose to connect and what your carrier provides.'
  },
  {
    question: 'What happens after I connect my information?',
    answer: 'We review the information and use it to provide more relevant guidance about life insurance options that may align with your current protection situation.'
  }
];
---
<BaseLayout title="Connect Your Insurance | Best Life Insurance Near Me" description="Help us understand your current protection. Connecting your insurance information through Canopy Connect helps us provide more relevant life insurance guidance." keywords="connect insurance, Canopy Connect, life insurance review, current coverage, household protection">
  <section class="connect-hero">
    <div class="container hero-wrap">
      <p class="eyebrow">Optional — but helpful</p>
      <h1>Help Us Understand Your Current Protection</h1>
      <p class="lead">Connecting your insurance information can help us understand the protections your household already has in place.</p>
      <p class="hero-support">Many people have existing coverage through employer benefits, existing life insurance policies, homeowners insurance, or other financial products. Seeing what's already in place helps us avoid unnecessary recommendations and focus on what may actually matter for your situation.</p>
    </div>
  </section>

  <!-- Security & Trust Section -->
  <section class="section trust-section">
    <div class="container">
      <div class="trust-header">
        <p class="eyebrow">Your security</p>
        <h2>Your Information Stays Secure</h2>
        <p class="lead">We understand that insurance information is personal. That's why we use Canopy Connect, a secure platform that helps consumers safely connect insurance information without emailing documents, uploading screenshots, or sharing account passwords with us.</p>
        <p class="trust-sub">The information you choose to connect is used to help us better understand your current protection and provide more relevant recommendations.</p>
      </div>
      <div class="trust-grid">
        {trustPoints.map((tp) => (
          <div class="trust-card">
            <span class="trust-icon" aria-hidden="true">{tp.icon}</span>
            <h3 class="trust-card-title">{tp.title}</h3>
            <p class="trust-card-desc">{tp.desc}</p>
          </div>
        ))}
      </div>
      <p class="trust-disclaimer">Available information depends on what you choose to connect and what your insurance carrier makes available through connected systems.</p>
    </div>
  </section>

  <!-- Canopy Connect Embed -->
  <section class="canopy-section">
    <div class="container canopy-card">
      <div class="canopy-copy">
        <p class="eyebrow">Connect securely</p>
        <h2>Help Us Understand Your Current Protection</h2>
        <p class="lead">This usually only takes a few minutes.</p>
        <p>The more we understand about your current coverage, the easier it is to provide relevant guidance about life insurance options.</p>
      </div>
      <div class="canopy-connect-wrap">
        <script src="https://cdn.usecanopy.com/v2/embed.js" async></script>
        <div data-canopy-connect-public-alias="best-life-insurance-near-me" style="width: 400px; height: 600px;" class="canopy-connect-mount"></div>
      </div>
    </div>
  </section>

  <!-- Why We Ask Section -->
  <section class="section why-section">
    <div class="container narrow">
      <p class="eyebrow">Why we ask</p>
      <h2>Why Are We Asking For This?</h2>
      <p class="lead">Our goal is not to collect unnecessary information.</p>
      <p>Many people already have protections in place through life insurance policies, employer benefits, homeowners insurance, auto insurance, or other financial products.</p>
      <p>By understanding what protections may already exist, we can provide more relevant guidance and help identify potential coverage gaps.</p>
      <p>Our goal is to help you make a more informed decision.</p>
    </div>
  </section>

  <!-- FAQ -->
  <section class="section faq-section">
    <div class="container narrow">
      <div class="section-heading">
        <p class="eyebrow">Questions</p>
        <h2>Common questions before you connect.</h2>
      </div>
      <div class="faq-list">
        {faqs.map((faq) => (
          <details>
            <summary>{faq.question}</summary>
            <p>{faq.answer}</p>
          </details>
        ))}
      </div>
    </div>
  </section>

  <section class="section next-step-section">
    <div class="container narrow">
      <div class="next-step-card">
        <div class="next-step-copy">
          <p class="eyebrow">Next step</p>
          <h2>Continue Exploring Your Options</h2>
          <p>Browse our coverage guides to understand the types of life insurance available. Or take the Family Protection Check if you haven&rsquo;t already.</p>
        </div>
        <div class="next-step-actions">
          <a href="/coverage/" class="next-step-btn">Browse Coverage Guides &rarr;</a>
          <a href="/family-protection-check/" class="next-step-btn-ghost">Take the Family Protection Check</a>
        </div>
      </div>
    </div>
  </section>
</BaseLayout>

<script>
  import { pushDataLayerEvent } from '../lib/dataLayer';
  import { captureAttribution } from '../lib/attribution';

  const attr = captureAttribution();
  const params = new URLSearchParams(window.location.search);

  const canopyBase = {
    lead_type: params.get('leadType') || 'canopy_connect',
    page_path: attr.current_page_path,
    referrer: attr.current_referrer,
    ...attr,
  };

  pushDataLayerEvent('canopy_page_view', canopyBase);

  const observer = new IntersectionObserver((entries) => {
    entries.forEach((entry) => {
      if (!entry.isIntersecting) return;
      const target = entry.target as HTMLElement;
      if (target.dataset.canopyObserved) return;
      target.dataset.canopyObserved = '1';
      if (target.classList.contains('canopy-connect-wrap')) {
        pushDataLayerEvent('canopy_embed_view', canopyBase);
      }
    });
  }, { threshold: 0.3 });

  const el = document.querySelector('.canopy-connect-wrap');
  if (el) observer.observe(el);
</script>

<style>
  .connect-hero { padding: 56px 0 28px; background: linear-gradient(135deg, #EBF0FA 0%, #FFFFFF 60%); }
  .hero-wrap { max-width: 980px; }
  .connect-hero h1 { max-width: 900px; font-size: clamp(2.45rem, 7vw, 5rem); }
  .connect-hero .lead { max-width: 820px; }
  .hero-support { color: var(--color-gray-700); font-size: 1.03rem; max-width: 820px; margin-bottom: 0; }

  .trust-section { background: var(--color-soft-cream); }
  .trust-header { max-width: 820px; margin-bottom: 36px; }
  .trust-sub { color: var(--color-gray-700); margin-bottom: 0; }
  .trust-grid { display: grid; grid-template-columns: repeat(4, 1fr); gap: 18px; }
  .trust-card { background: var(--color-white); border: 1px solid rgba(31,41,55,.10); border-radius: var(--radius-md); padding: 24px; box-shadow: 0 8px 24px rgba(16,32,51,.07); }
  .trust-icon { display: block; font-size: 1.8rem; margin-bottom: 10px; }
  .trust-card-title { font-size: 1rem; font-weight: 900; color: var(--color-navy); margin: 0 0 6px; }
  .trust-card-desc { font-size: .9rem; color: var(--color-gray-700); margin: 0; line-height: 1.5; }
  .trust-disclaimer { margin-top: 20px; font-size: .88rem; color: var(--color-gray-600); font-style: italic; }

  .canopy-section { padding: 56px 0; background: var(--color-white); }
  .canopy-card { display: grid; grid-template-columns: 1fr 1fr; gap: 48px; align-items: start; }
  .canopy-copy { max-width: 480px; }
  .canopy-copy h2 { font-size: clamp(2rem, 5vw, 3.4rem); }
  .canopy-connect-wrap { display: flex; justify-content: center; align-items: flex-start; }

  .narrow { max-width: 850px; }
  .why-section { background: var(--color-soft-cream); }
  .section-heading { max-width: 780px; margin-bottom: 24px; }
  .faq-section { background: var(--color-white); }
  .faq-list { display: grid; gap: 12px; }
  details { background: var(--color-white); border: 1px solid rgba(31,41,55,.10); border-radius: var(--radius-md); overflow: hidden; }
  summary { cursor: pointer; padding: 18px 20px; color: var(--color-navy); font-weight: 950; list-style-position: inside; }
  details p { margin: 0; padding: 0 20px 20px; color: var(--color-gray-700); }

  .next-step-section { background: var(--color-soft-cream); }
  .next-step-card { background: var(--color-white); border: 1px solid rgba(31,41,55,.10); border-radius: var(--radius-lg); box-shadow: var(--shadow-card); padding: 34px; display: grid; gap: 24px; }
  .next-step-copy h2 { font-size: clamp(1.6rem, 4vw, 2.6rem); margin-bottom: 12px; }
  .next-step-actions { display: flex; flex-wrap: wrap; gap: 14px; align-items: center; }
  .next-step-btn { display: inline-flex; align-items: center; background: var(--color-blue); color: var(--color-white); font-weight: 950; border-radius: 999px; padding: 15px 26px; font-size: 1rem; }
  .next-step-btn:hover { filter: brightness(.94); color: var(--color-white); }
  .next-step-btn-ghost { display: inline-flex; align-items: center; color: var(--color-navy); font-weight: 900; border: 2px solid rgba(16,32,51,.15); border-radius: 999px; padding: 14px 24px; font-size: 1rem; }
  .next-step-btn-ghost:hover { border-color: var(--color-navy); }

  @media (max-width: 900px) {
    .trust-grid { grid-template-columns: repeat(2, 1fr); }
    .canopy-card { grid-template-columns: 1fr; }
    .connect-hero { padding: 42px 0 20px; }
  }
  @media (max-width: 620px) {
    .trust-grid { grid-template-columns: 1fr; }
    .canopy-connect-wrap :global([data-canopy-connect-public-alias]) { width: 100% !important; }
  }
</style>
