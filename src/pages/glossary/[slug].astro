---
import { getCollection, render } from 'astro:content';
import ContentLayout from '../../layouts/ContentLayout.astro';
import { findEntryBySlug } from '../../lib/contentPaths';

export async function getStaticPaths() {
  const entries = await getCollection('glossary');

  return entries.map((entry) => ({
    params: { slug: entry.id }
  }));
}
const entries = await getCollection('glossary');
const entry = findEntryBySlug(entries, Astro.params.slug);
const { Content } = await render(entry);
---
<ContentLayout title={entry.data.title} description={entry.data.description} seoTitle={entry.data.seoTitle} seoDescription={entry.data.seoDescription} eyebrow="Glossary"><Content /></ContentLayout>
