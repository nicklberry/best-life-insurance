---
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import CookieBanner from '../components/CookieBanner.astro';
import '../styles/global.css';
interface Props {
  title: string;
  description: string;
  canonical?: string;
  keywords?: string;
  image?: string;
  noindex?: boolean;
}
const {
  title,
  description,
  canonical,
  keywords = 'life insurance, best life insurance, life insurance near me, term life insurance, whole life insurance, family protection, life insurance quotes',
  image = '/best-life-insurance-og.png',
  noindex = false
} = Astro.props;
const canonicalUrl = canonical ? new URL(canonical, Astro.site) : new URL(Astro.url.pathname, Astro.site);
const imageUrl = new URL(image, Astro.site);
---
<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <meta name="keywords" content={keywords} />
    {noindex && <meta name="robots" content="noindex, nofollow" />}
    <link rel="canonical" href={canonicalUrl.href} />
    <meta property="og:site_name" content="Best Life Insurance Near Me" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content="website" />
    <meta property="og:url" content={canonicalUrl.href} />
    <meta property="og:image" content={imageUrl.href} />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta property="og:image:alt" content="Best Life Insurance Near Me life insurance guides" />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={imageUrl.href} />
    <meta name="theme-color" content="#FFFFFF" />
    <!-- Google Tag Manager -->
    <script>(function(w,d,s,l,i){w[l]=w[l]||[];w[l].push({'gtm.start':
new Date().getTime(),event:'gtm.js'});var f=d.getElementsByTagName(s)[0],
j=d.createElement(s),dl=l!='dataLayer'?'&l='+l:'';j.async=true;j.src=
'https://www.googletagmanager.com/gtm.js?id='+i+dl;f.parentNode.insertBefore(j,f);
})(window,document,'script','dataLayer','GTM-NXHZXKHC');</script>
    <!-- End Google Tag Manager -->
  </head>
  <body>
    <!-- Google Tag Manager (noscript) -->
    <noscript><iframe src="https://www.googletagmanager.com/ns.html?id=GTM-NXHZXKHC"
height="0" width="0" style="display:none;visibility:hidden"></iframe></noscript>
    <!-- End Google Tag Manager (noscript) -->
    <Header />
    <main><slot /></main>
    <Footer />
    <CookieBanner />
  </body>
</html>

<script>
  import { pushDataLayerEvent } from '../lib/dataLayer';
  import { captureAttribution } from '../lib/attribution';

  function getContentType(path: string): string {
    if (path === '/') return 'home';
    if (path.startsWith('/life-insurance/')) {
      const parts = path.split('/').filter(Boolean);
      return parts.length >= 3 ? 'territory_city' : 'territory_state';
    }
    if (path.startsWith('/coverage/')) return 'coverage_guide';
    if (path.startsWith('/blog/')) return 'blog';
    if (path.startsWith('/glossary/')) return 'glossary';
    const toolPaths = ['/family-protection-check/', '/connect-insurance/', '/recommendations/'];
    if (toolPaths.includes(path)) return 'tool';
    if (path === '/compare/') return 'compare';
    if (path === '/contact/') return 'contact';
    if (path === '/about/') return 'about';
    return 'page';
  }

  function getCluster(path: string): string {
    const clusterMap: Record<string, string> = {
      '/family-protection-check/': 'family_protection_check',
      '/connect-insurance/': 'canopy_connect',
      '/recommendations/': 'recommendations',
    };
    if (clusterMap[path]) return clusterMap[path];
    const parts = path.split('/').filter(Boolean);
    if (parts.length >= 2 && ['coverage', 'blog', 'glossary'].includes(parts[0])) return parts[1];
    return '';
  }

  const path = window.location.pathname;
  const attr = captureAttribution();

  pushDataLayerEvent('page_view_enhanced', {
    page_url: attr.current_page_url,
    page_path: path,
    page_title: document.title,
    content_type: getContentType(path),
    cluster: getCluster(path),
    ...attr,
  });
</script>
