---
interface Props { href: string; variant?: 'primary' | 'secondary' | 'ghost'; label?: string; }
const { href, variant = 'primary', label } = Astro.props;
---
<a class={`btn btn-${variant}`} href={href}><slot>{label}</slot></a>
<style>
  .btn { display: inline-flex; align-items: center; justify-content: center; gap: 10px; border-radius: 999px; padding: 14px 20px; font-weight: 900; border: 2px solid transparent; transition: transform .15s ease, box-shadow .15s ease; }
  .btn:hover { transform: translateY(-1px); color: inherit; }
  .btn-primary { background: var(--color-orange); color: var(--color-white); box-shadow: 0 14px 30px rgba(249, 115, 22, .28); }
  .btn-secondary { background: var(--color-white); color: var(--color-navy); border-color: rgba(16, 32, 51, .14); }
  .btn-ghost { color: var(--color-navy); background: transparent; border-color: rgba(16, 32, 51, .12); }
</style>
