---
import Disclaimer from './Disclaimer.astro';
---
<footer class="site-footer">
  <div class="container footer-grid">
    <div>
      <a class="brand" href="/">
        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" aria-hidden="true"><path d="M12 2C6.48 2 2 6.48 2 12s4.48 10 10 10 10-4.48 10-10S17.52 2 12 2zm-1 14H9V8h2v8zm4 0h-2V8h2v8z" fill="white"/></svg>
        Best Life Insurance Near Me
      </a>
      <p>A trusted family protection resource. Plain-English guides, coverage explanations, and planning tools to help you understand your options.</p>
      <Disclaimer insurance />
    </div>
    <div><h3>Coverage</h3><a href="/coverage/term-life/">Term Life</a><a href="/coverage/whole-life/">Whole Life</a><a href="/coverage/universal-life/">Universal Life</a><a href="/coverage/final-expense/">Final Expense</a><a href="/coverage/no-medical-exam/">No Medical Exam</a></div>
    <div><h3>Resources</h3><a href="/compare/">Compare</a><a href="/blog/">Blog</a><a href="/glossary/">Glossary</a><a href="/territories/">Territories</a></div>
    <div><h3>Company</h3><a href="/about/">About</a><a href="/contact/">Contact</a><a href="/privacy/">Privacy</a><a href="/terms/">Terms</a></div>
  </div>
  <div class="container fine-print">© {new Date().getFullYear()} Best Life Insurance Near Me. Educational information only — not legal, financial, or insurance advice.</div>
</footer>
<style>
.site-footer{background:var(--color-navy);color:#D8E0EA;padding:56px 0 24px}.footer-grid{display:grid;grid-template-columns:2fr 1fr 1fr 1fr;gap:32px}.brand{display:inline-flex;align-items:center;gap:8px;color:white;font-weight:950;margin-bottom:14px}.site-footer h3{color:white;font-size:1rem;letter-spacing:0;margin-bottom:10px}.site-footer a{display:block;color:#EEF4FA;margin:6px 0;font-size:.93rem}.site-footer a:hover{color:#93C5FD}.fine-print{margin-top:32px;padding-top:20px;border-top:1px solid rgba(255,255,255,.14);font-size:.85rem;color:#B8C5D4}@media(max-width:760px){.footer-grid{grid-template-columns:1fr 1fr}}@media(max-width:500px){.footer-grid{grid-template-columns:1fr}}
</style>
