---
import BaseLayout from '../layouts/BaseLayout.astro';
import LeadCaptureGate from './LeadCaptureGate.astro';
import TrustStrip from './TrustStrip.astro';
import HowItWorks from './HowItWorks.astro';
import CTASection from './CTASection.astro';
import type { LocalCity } from '../data/locations';

interface Props {
  stateName: string;
  stateAbbreviation: string;
  stateSlug: string;
  cityName?: string;
  citySlug?: string;
  population?: number;
  isCityPage: boolean;
  isActiveMarket: boolean;
  localPainPoints?: string[];
  cities?: LocalCity[];
}

const {
  stateName,
  stateAbbreviation,
  stateSlug,
  cityName,
  citySlug,
  population,
  isCityPage,
  isActiveMarket,
  localPainPoints = [],
  cities = [],
} = Astro.props;

const defaultLocalPainPoints = [
  "Aging HVAC systems",
  "Water heater repairs",
  "Plumbing surprises",
  "Kitchen appliance breakdowns",
  "Electrical system issues",
];

const painPoints = localPainPoints.length > 0 ? localPainPoints : defaultLocalPainPoints;

const locationLabel = isCityPage && cityName ? `near ${cityName}, ${stateAbbreviation}` : `in ${stateName}`;
const locationShort = isCityPage && cityName ? cityName : stateName;
const locationName = isCityPage && cityName ? cityName : stateName;

const seoTitle = isCityPage && cityName
  ? `Home Warranty Options Near ${cityName}, ${stateAbbreviation}`
  : `Home Warranty Options in ${stateName}`;

const seoDescription = isCityPage && cityName
  ? `Compare home warranty options near ${cityName}, ${stateAbbreviation}. Learn what may be covered, what exclusions matter, and how to check availability.`
  : `Compare home warranty options in ${stateName}. Learn what may be covered, what exclusions matter, and how to check availability near you.`;

const canonicalPath = isCityPage && citySlug
  ? `/home-warranty/${stateSlug}/${citySlug}/`
  : `/home-warranty/${stateSlug}/`;

const heroHeadline = isCityPage && cityName
  ? `Compare home warranty options near ${cityName}, ${stateAbbreviation}`
  : `Compare home warranty options in ${stateName}`;

const heroSubheadline = isCityPage && cityName
  ? `Your house does not care that repair bills are inconvenient. Compare home warranty options near ${cityName} for major systems and appliances before something expensive picks a fight with your budget.`
  : `Your house does not care that repair bills are inconvenient. Compare home warranty options for major systems and appliances before something expensive picks a fight with your budget.`;

const localRepairRiskCopy = isCityPage && cityName
  ? `Homeowners near ${cityName} may deal with repair risks like aging HVAC systems, water heater issues, plumbing surprises, and appliance breakdowns. A home warranty may help with certain covered repairs depending on the provider, plan, location, and contract terms.`
  : `Homeowners across ${stateName} may face repair risks tied to older systems, changing seasons, aging appliances, and surprise breakdowns. A home warranty may help with certain covered repairs depending on the provider, plan, location, and contract terms.`;

const statePagePath = `/home-warranty/${stateSlug}/`;
---

<BaseLayout title={seoTitle} description={seoDescription} canonical={canonicalPath}>

  <!-- 1. Hero with LeadCaptureGate -->
  <section class="local-hero">
    <div class="container local-hero-grid">
      <div class="local-hero-copy">
        {isCityPage && cityName
          ? <p class="eyebrow">Home Warranty &mdash; {stateName}</p>
          : <p class="eyebrow">Home Warranty</p>
        }
        <h1>{heroHeadline}</h1>
        <p class="lead">{heroSubheadline}</p>
        {isCityPage && (
          <p class="state-back muted">Also see: <a href={statePagePath}>Home warranty options in {stateName}</a></p>
        )}
      </div>
      <div class="local-hero-gate">
        <LeadCaptureGate compact />
      </div>
    </div>
  </section>

  <!-- 2. Trust strip -->
  <TrustStrip />

  <!-- 3. Local repair risk section -->
  <section class="section local-risk-section">
    <div class="container local-risk-grid">
      <div>
        <p class="eyebrow">Local repair risk</p>
        <h2>{isCityPage && cityName ? `Home repairs near ${cityName} can get expensive fast` : `Home repairs in ${stateName} can get expensive fast`}</h2>
        <p>{localRepairRiskCopy}</p>
      </div>
      <ul class="list-check pain-points">
        {painPoints.map((point) => <li>{point}</li>)}
      </ul>
    </div>
  </section>

  <!-- 4. What home warranties may help cover -->
  <section class="section">
    <div class="container">
      <p class="eyebrow">What&rsquo;s covered</p>
      <h2>What home warranties may help cover</h2>
      <p class="lead coverage-intro">Coverage varies by provider, plan, and contract terms. These are common categories. Read the fine print before assuming anything is included.</p>
      <div class="grid grid-3">
        <a class="card coverage-link-card" href="/coverage/hvac/">
          <h3>HVAC Systems</h3>
          <p>Heating, cooling, and ventilation. Often the most expensive home system to repair or replace. Coverage terms and caps vary significantly by provider.</p>
        </a>
        <a class="card coverage-link-card" href="/coverage/plumbing/">
          <h3>Plumbing</h3>
          <p>Water supply lines, drain lines, and some fixtures. What sits inside walls or underground may or may not be included depending on the plan.</p>
        </a>
        <a class="card coverage-link-card" href="/coverage/electrical/">
          <h3>Electrical Systems</h3>
          <p>Wiring, panels, and outlets. Panels flagged as safety hazards by providers may be excluded. Check the contract before assuming coverage.</p>
        </a>
        <a class="card coverage-link-card" href="/coverage/water-heater/">
          <h3>Water Heater</h3>
          <p>Tank and tankless models may be covered. Age limits and sediment buildup exclusions appear frequently across providers.</p>
        </a>
        <a class="card coverage-link-card" href="/coverage/kitchen-appliances/">
          <h3>Kitchen Appliances</h3>
          <p>Refrigerator, dishwasher, range, oven, and built-in microwave. Coverage limits and per-claim service fees vary widely.</p>
        </a>
        <a class="card coverage-link-card" href="/coverage/laundry-appliances/">
          <h3>Laundry Appliances</h3>
          <p>Washer and dryer when mechanical failure from normal use is the cause. Abuse or neglect is typically excluded.</p>
        </a>
      </div>
      <p class="coverage-footnote muted">All coverage terms depend on the specific plan and contract.</p>
    </div>
  </section>

  <!-- 5. What home warranties usually do not cover -->
  <section class="section section-soft">
    <div class="container not-covered-grid">
      <div>
        <p class="eyebrow">Know before you buy</p>
        <h2>What home warranties usually do not cover</h2>
        <p>These exclusions appear frequently across providers. Treat them as starting questions when comparing plans, not surprises after a claim.</p>
      </div>
      <ul class="list-x exclusions-list">
        <li>Pre-existing conditions or known defects at time of purchase</li>
        <li>Cosmetic damage that does not affect function</li>
        <li>Code upgrades required during repair or replacement</li>
        <li>Systems and appliances not listed in your specific contract</li>
        <li>Damage from improper installation or neglected maintenance</li>
        <li>Damage from pests, floods, fire, or external causes</li>
        <li>Commercial-grade equipment used in a residential setting</li>
        <li>Secondary structures, outdoor equipment, or detached garages</li>
      </ul>
    </div>
  </section>

  <!-- 6. How it works -->
  <HowItWorks />

  <!-- 7. Active market explanation -->
  <section class="section">
    <div class="container">
      <div class={`availability-card ${isActiveMarket ? 'availability-active' : 'availability-waitlist'}`}>
        {isActiveMarket ? (
          <>
            <p class="eyebrow">Active market</p>
            <h2>We are helping homeowners {locationLabel}</h2>
            <p>Good news. We are currently helping homeowners in {locationName} compare home warranty options and connect with participating licensed insurance professionals when helpful.</p>
            <p class="muted">Enter your ZIP code at the top of this page to check availability and see what options may apply to your specific address.</p>
          </>
        ) : (
          <>
            <p class="eyebrow">Coming soon</p>
            <h2>We are not fully active in {stateName} yet</h2>
            <p>We are not fully active in {stateName} yet, but you can join the list and we will let you know when coverage options expand in your area.</p>
            <p class="muted">Enter your ZIP code at the top of this page to join the waitlist.</p>
          </>
        )}
      </div>
    </div>
  </section>

  <!-- 8. FAQ -->
  <section class="section section-soft">
    <div class="container">
      <p class="eyebrow">Common questions</p>
      <h2>Frequently asked questions {locationLabel}</h2>
      <div class="faq-list">
        <div class="faq-item">
          <h3>Are home warranties available {locationLabel}?</h3>
          <p>
            {isActiveMarket
              ? `Yes. We are currently helping homeowners in ${stateName} compare home warranty options. Coverage availability and plan terms vary by provider and ZIP code.`
              : `We are not fully active in ${stateName} yet. You can join our waitlist and we will notify you when options become available in your area.`}
          </p>
        </div>
        <div class="faq-item">
          <h3>What does a home warranty typically cover?</h3>
          <p>Most plans cover major home systems like HVAC, plumbing, and electrical, along with common appliances like refrigerators, dishwashers, and washers and dryers. Coverage limits, service fees, and exclusions vary significantly by provider and plan. There is no standard contract.</p>
        </div>
        <div class="faq-item">
          <h3>Is a home warranty the same as homeowners insurance?</h3>
          <p>No. Homeowners insurance covers sudden damage from external events like fire, theft, or storms. A home warranty covers mechanical failure of covered systems and appliances from normal wear and tear. Most homeowners need both, not one instead of the other.</p>
        </div>
        <div class="faq-item">
          <h3>How do I choose a home warranty plan?</h3>
          <p>Start by identifying which systems and appliances in your home are most likely to need attention. Compare what each plan covers, the annual cost, the per-claim service fee, and the coverage cap for each item. Read the full contract before committing.</p>
        </div>
        <div class="faq-item">
          <h3>Is there a waiting period before coverage starts?</h3>
          <p>Most home warranty contracts include a 30-day waiting period after purchase before claims are accepted. Some providers waive this for homes purchased during a real estate transaction. Verify the waiting period before assuming immediate coverage applies.</p>
        </div>
        {isCityPage && cityName && (
          <div class="faq-item">
            <h3>What should homeowners near {cityName} watch out for?</h3>
            <p>Local housing stock, climate, and construction era affect which systems are most likely to need repair. Use our coverage guides to understand what may be covered, then check availability with your specific ZIP code to see what plans apply to your address.</p>
          </div>
        )}
      </div>
    </div>
  </section>

  <!-- State pages: city links grid -->
  {!isCityPage && cities.length > 0 && (
    <section class="section city-links-section">
      <div class="container">
        <p class="eyebrow">Cities in {stateName}</p>
        <h2>Home warranty options by city in {stateName}</h2>
        <p class="lead">Select a city below to see local repair risks, coverage options, and availability near you.</p>
        <ul class="city-links-grid">
          {cities.map((city) => (
            <li>
              <a href={`/home-warranty/${stateSlug}/${city.slug}/`} class="city-link-card">
                <span class="city-link-name">{city.name}</span>
                <span class="city-link-arrow">&rarr;</span>
              </a>
            </li>
          ))}
        </ul>
      </div>
    </section>
  )}

  <!-- City pages: back to state link -->
  {isCityPage && (
    <section class="section state-link-section">
      <div class="container">
        <p class="state-link-copy">See more home warranty options in <a href={statePagePath}>{stateName}</a>.</p>
      </div>
    </section>
  )}

  <!-- 9. Final CTA -->
  <CTASection
    title={`Before something expensive breaks ${locationLabel}, compare your options.`}
    text={`Start with your ZIP code. We'll help you understand what may be covered and what to watch out for near ${locationShort}.`}
    showLeadGate
  />

</BaseLayout>

<script define:vars={{ stateAbbreviation, stateName, cityName: cityName ?? '', isCityPage, isActiveMarket }}>
  // @ts-ignore - injected via define:vars
  const _stateAbbreviation = stateAbbreviation;
  // @ts-ignore
  const _stateName = stateName;
  // @ts-ignore
  const _cityName = cityName;
  // @ts-ignore
  const _isCityPage = isCityPage;
  // @ts-ignore
  const _isActiveMarket = isActiveMarket;

  /** @type {(name: string, data?: Record<string, unknown>) => void} */
  function pushDL(name, data = {}) {
    window.dataLayer = window.dataLayer || [];
    window.dataLayer.push({ event: name, ...data });
  }

  const params = new URLSearchParams(window.location.search);
  const territoryBase = {
    market: _isCityPage ? _cityName : _stateName,
    state: _stateAbbreviation,
    territory_type: _isCityPage ? 'city' : 'state',
    page_path: window.location.pathname,
    current_page_url: window.location.href,
    current_page_path: window.location.pathname,
    current_page_title: document.title,
    current_referrer: document.referrer,
    current_utm_source: params.get('utm_source') || '',
    current_utm_medium: params.get('utm_medium') || '',
    current_utm_campaign: params.get('utm_campaign') || '',
    current_utm_term: params.get('utm_term') || '',
    current_utm_content: params.get('utm_content') || '',
  };

  pushDL('territory_page_view', territoryBase);

  // CTA clicks: ZIP form submission
  document.querySelectorAll('[data-zip-form]').forEach((form) => {
    form.addEventListener('submit', () => {
      pushDL('territory_cta_click', territoryBase);
    });
  });

  // City link clicks: market interest
  document.querySelectorAll('.city-link-card').forEach((link) => {
    link.addEventListener('click', () => {
      const cityName = link.querySelector('.city-link-name')?.textContent?.trim() || '';
      pushDL('territory_market_interest', { ...territoryBase, clicked_city: cityName });
    });
  });
</script>

<style>
  .local-hero {
    padding: 76px 0 42px;
    background: radial-gradient(circle at top right, #FFE4C7, transparent 34%), var(--color-cream);
  }
  .local-hero-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 48px;
    align-items: start;
  }
  .local-hero-copy h1 {
    margin-bottom: 20px;
  }
  .state-back {
    margin-top: 4px;
    font-size: .95rem;
  }
  .state-back a {
    color: var(--color-orange);
    font-weight: 800;
  }
  .section-soft {
    background: var(--color-soft-cream);
  }
  .local-risk-section {
    background: var(--color-white);
  }
  .local-risk-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 48px;
    align-items: start;
  }
  .coverage-intro {
    margin-bottom: 28px;
  }
  .coverage-link-card {
    display: block;
    transition: transform .12s ease, box-shadow .12s ease;
    text-decoration: none;
    color: inherit;
  }
  .coverage-link-card:hover {
    transform: translateY(-2px);
    box-shadow: 0 24px 64px rgba(16, 32, 51, .14);
    color: inherit;
  }
  .coverage-link-card h3 {
    color: var(--color-navy);
    margin-bottom: 10px;
  }
  .coverage-link-card p {
    color: var(--color-gray-700);
    font-size: .95rem;
    margin: 0;
  }
  .coverage-footnote {
    margin-top: 20px;
    font-size: .9rem;
  }
  .coverage-footnote a {
    color: var(--color-orange);
    font-weight: 800;
  }
  .not-covered-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 48px;
    align-items: start;
  }
  .exclusions-list {
    margin: 0;
  }
  .pain-points {
    margin: 0;
  }
  .availability-card {
    border-radius: var(--radius-lg);
    padding: 36px 40px;
    max-width: 700px;
  }
  .availability-active {
    background: #ECFDF5;
    border: 1px solid #A7F3D0;
  }
  .availability-waitlist {
    background: #FFFBEB;
    border: 1px solid #FDE68A;
  }
  .availability-card h2 {
    font-size: clamp(1.5rem, 3.5vw, 2.4rem);
    margin-bottom: 12px;
  }
  .availability-card p {
    margin-bottom: 8px;
  }
  .faq-list {
    margin-top: 28px;
  }
  .faq-item {
    padding: 24px 0;
    border-bottom: 1px solid rgba(31, 41, 55, .1);
  }
  .faq-item:first-child {
    border-top: 1px solid rgba(31, 41, 55, .1);
  }
  .faq-item h3 {
    font-size: clamp(1rem, 2vw, 1.2rem);
    margin-bottom: 8px;
    letter-spacing: -.02em;
  }
  .faq-item p {
    color: var(--color-gray-700);
    margin: 0;
  }
  .city-links-section {
    background: var(--color-cream);
  }
  .city-links-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(200px, 1fr));
    gap: 12px;
    list-style: none;
    padding: 0;
    margin: 28px 0 0;
  }
  .city-link-card {
    display: flex;
    justify-content: space-between;
    align-items: center;
    background: var(--color-white);
    border: 1px solid rgba(31, 41, 55, .10);
    border-radius: var(--radius-lg);
    padding: 14px 18px;
    text-decoration: none;
    color: var(--color-navy);
    font-weight: 800;
    transition: box-shadow .12s ease, transform .12s ease;
    box-shadow: var(--shadow-card);
  }
  .city-link-card:hover {
    transform: translateY(-2px);
    box-shadow: 0 12px 32px rgba(16, 32, 51, .12);
    color: var(--color-navy);
  }
  .city-link-name {
    font-size: .95rem;
  }
  .city-link-arrow {
    color: var(--color-orange);
    font-size: 1.1rem;
  }
  .state-link-section {
    background: var(--color-soft-cream);
    padding: 28px 0;
  }
  .state-link-copy {
    font-size: 1rem;
    color: var(--color-gray-700);
    margin: 0;
  }
  .state-link-copy a {
    color: var(--color-orange);
    font-weight: 800;
  }
  @media (max-width: 820px) {
    .local-hero-grid,
    .not-covered-grid,
    .local-risk-grid {
      grid-template-columns: 1fr;
    }
    .local-hero {
      padding: 52px 0 32px;
    }
    .availability-card {
      padding: 24px;
    }
    .city-links-grid {
      grid-template-columns: repeat(auto-fill, minmax(160px, 1fr));
    }
  }
</style>
